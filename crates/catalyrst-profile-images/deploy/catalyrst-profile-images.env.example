# Template for catalyrst-profile-images.env
# catalyrst-profile-images — Rust port of profile-images.decentraland.org
#
# Serves avatar thumbnails on the upstream S3/CDN contract:
#   GET /entities/{entityId}/face.png   -> image/png (256x256)
#   GET /entities/{entityId}/body.png   -> image/png (256x512)
#
# PRIMARY BACKEND: local render (PROFILE_IMAGES_BACKEND=render). On a cache
# miss the service resolves the profile entity from the local catalyrst content
# core, renders its equipped wearables to PNGs with the headless godot-explorer
# avatar renderer (`decentraland.godot.client --avatar-renderer`, exactly as
# upstream's producer/consumer rig does), caches both PNGs, and serves them.
# Concurrent requests for the same entity collapse to a single render
# (single-flight). The prod proxy is an OPTIONAL last-resort fallback, not the
# default. See the crate README.
#
# Copy to catalyrst-profile-images.env (gitignored, mode 600) and adjust.

HTTP_SERVER_HOST=127.0.0.1
HTTP_SERVER_PORT=8080

# Backend selection:
#   render   — local headless-Godot avatar render (PRIMARY; needs the godot
#              client binary + a GL context, see below)
#   proxy    — origin-pull from PROFILE_IMAGES_ORIGIN_URL (no local render)
#   disabled — cache-only; 404 on miss (offline / tests)
# When unset: render if PROFILE_IMAGES_CONTENT_URL is set, else proxy if an
# origin URL is set, else disabled.
PROFILE_IMAGES_BACKEND=render

# --- render backend ---------------------------------------------------------
# Local catalyst content base (WITH the /content suffix). Used to resolve the
# profile entity (GET <base>/contents/<entityId> -> metadata.avatars[0].avatar)
# AND handed to the renderer as its wearable-lookup baseUrl.
PROFILE_IMAGES_CONTENT_URL=http://127.0.0.1:8081/content

# Path to the EXPORTED godot client binary produced by:
#   cd <godot-explorer> && cargo run -- build -r && cargo run -- export --target linux
# (artifact: exports/decentraland.godot.client.x86_64). REQUIRED for render.
PROFILE_IMAGES_GODOT_BIN=<CONTENT_ROOT>/godot-explorer/exports/decentraland.godot.client.x86_64
# Godot project root to spawn from (so the gdextension's relative
# libdclgodot.so resolves). Defaults to <godot_bin>/../.. when unset.
PROFILE_IMAGES_GODOT_PROJECT=<CONTENT_ROOT>/godot-explorer

# Renderer flags (defaults match scripts/local_profile_snapshot.sh):
PROFILE_IMAGES_RENDERING_METHOD=gl_compatibility
PROFILE_IMAGES_RENDERING_DRIVER=opengl3
# Wearable-lookup environment: org (mainnet) | zone (Amoy testnet) | today.
# Required to render testnet wearables; leave unset for mainnet (org).
#PROFILE_IMAGES_DCLENV=org
# Pass --headless to godot. Only enable if you have Xvfb / EGL surfaceless set
# up — the renderer needs a real GL context to actually draw the avatar.
PROFILE_IMAGES_GODOT_HEADLESS=false
# DISPLAY for the child (X11). Point at an Xvfb/real display when not headless.
#PROFILE_IMAGES_GODOT_DISPLAY=:99
# Extra raw args appended to the godot invocation (space separated).
#PROFILE_IMAGES_GODOT_EXTRA_ARGS=
# Per-render wall-clock timeout (seconds) and max concurrent godot processes.
PROFILE_IMAGES_RENDER_TIMEOUT_SECONDS=120
PROFILE_IMAGES_RENDER_MAX_CONCURRENT=1
# Scratch dir for per-render avatars.json + output PNGs. Defaults to
# <cache_dir>/.render-tmp.
#PROFILE_IMAGES_RENDER_WORKDIR=<DATA_DIR>/profile-images/.render-tmp

# Explicit last-resort: when a local render FAILS, fall back to the prod proxy
# instead of returning 502. Off by default — keep the proxy out of the hot path.
PROFILE_IMAGES_RENDER_FALLBACK_PROXY=false

# --- proxy backend / render fallback ----------------------------------------
# Prod origin base. Required for PROFILE_IMAGES_BACKEND=proxy, and for
# PROFILE_IMAGES_RENDER_FALLBACK_PROXY=true.
PROFILE_IMAGES_ORIGIN_URL=https://profile-images.decentraland.org

# --- cache ------------------------------------------------------------------
# Disk cache. Layout: <dir>/<sha256(entity)[0:2]>/<entity>/{face,body}.png
PROFILE_IMAGES_CACHE_DIR=<DATA_DIR>/profile-images
# Re-render / re-pull once a cached entry is older than this (seconds).
# 0 = never expire (serve cached forever once present).
PROFILE_IMAGES_CACHE_TTL_SECONDS=86400

RUST_LOG=catalyrst_profile_images=info,tower_http=info
