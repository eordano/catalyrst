# catalyrst-presence — unified user-count history collector + read API.
# Install to <WORKSPACE>/env/catalyrst-presence.env
#
# Replaces three earlier standalone archivers (archipelago / comms / worlds-
# membership). Reads from the LOCAL catalyrst services, not public DCL endpoints.

# --- HTTP read API ---
HTTP_SERVER_HOST=127.0.0.1
HTTP_SERVER_PORT=5152

# --- Postgres (unified presence archive) ---
# Prefer the unix-socket connection-string form against the shared cluster.
PRESENCE_PG_COMPONENT_PSQL_CONNECTION_STRING="postgresql:///presence?host=<DB_HOST>&port=5433&user=<DB_USER>&password=<DB_PASSWORD>"

# --- Upstream sources ---
# Local archipelago service: GET /peers, /islands, /hot-scenes.
ARCHIPELAGO_URL=http://127.0.0.1:5139
# Local comms service: GET /scene-participants?pointer=<base>&realm_name=<realm>
#                  and GET /scene-participants?realm_name=<world>
COMMS_URL=http://127.0.0.1:5138
# Worlds discovery (no local equivalent): GET /live-data.
WORLDS_SERVER_URL=https://worlds-content-server.decentraland.org

# Genesis realm name used when querying comms for hot-scene occupancy.
PRESENCE_GENESIS_REALM=main

# --- Collector daemon ---
# Seconds between snapshot passes in `run` mode (default 300 = 5 min).
PRESENCE_SNAPSHOT_INTERVAL_SECS=300

RUST_LOG=catalyrst_presence=info,tower_http=info
