# catalyrst-governance — archiver + read API over the Decentraland governance API
# Install to <WORKSPACE>/env/catalyrst-governance.env

# --- HTTP server -----------------------------------------------------------
# Bind address and port for the read API. Services bind 127.0.0.1.
HTTP_SERVER_HOST=127.0.0.1
HTTP_SERVER_PORT=5151

# --- Postgres --------------------------------------------------------------
# Connection string for the governance archive database (REQUIRED).
# Prefer the unix-socket form against the shared cluster on port 5433.
GOVERNANCE_PG_COMPONENT_PSQL_CONNECTION_STRING="postgresql:///governance?host=<DB_HOST>&port=5433&user=<DB_USER>&password=<DB_PASSWORD>"

# --- Upstream API ----------------------------------------------------------
# Base URL of the Decentraland governance API (no trailing slash needed).
GOVERNANCE_API_URL=https://governance.decentraland.org/api

# --- Background sync -------------------------------------------------------
# When true, `serve` spawns a background loop that runs an incremental sync
# every GOVERNANCE_SYNC_WINDOW_HOURS. Default: false.
GOVERNANCE_POLL_ENABLED=false

# Look-back window AND loop cadence, in hours. Default: 48.
GOVERNANCE_SYNC_WINDOW_HOURS=48

# --- Logging ---------------------------------------------------------------
RUST_LOG=catalyrst_governance=info,tower_http=info
