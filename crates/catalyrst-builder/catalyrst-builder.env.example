# catalyrst-builder — Rust port of builder-api.decentraland.org
# Copy to <CONFIG_DIR>/catalyrst-builder.env and fill the DB url.

HTTP_SERVER_HOST=127.0.0.1
HTTP_SERVER_PORT=5141

# Point at your PostgreSQL instance. Provision a dedicated 'builder' DB + role.
BUILDER_PG_CONNECTION_STRING="postgresql://<DB_USER>:<DB_PASSWORD>@<HOST>:5433/builder"

# Base URL that GET/HEAD /v1/storage/contents/{hash} 301-redirects to.
# The handler appends `contents/{hash}` (and optional `?ts=`), mirroring upstream's
# getBucketURL()/getFileKey. Default is the public builder bucket.
BUILDER_CONTENT_BUCKET_URL="https://builder-items.decentraland.org"

# Optional: comma-separated admin/committee addresses allowed to read any
# collection's items regardless of ownership (lower-cased on load).
# BUILDER_ADMIN_ADDRESSES=0xabc...,0xdef...

# Optional: external newsletter SaaS to forward POST /v1/newsletter to.
# NEWSLETTER_SERVICE_URL=https://newsletter.example/subscribe
# NEWSLETTER_SERVICE_BEARER=server-side-bearer-key

RUST_LOG=catalyrst_builder=info,tower_http=info
