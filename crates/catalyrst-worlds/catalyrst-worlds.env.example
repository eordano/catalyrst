# catalyrst-worlds — Rust port of decentraland/worlds-content-server (port 5141)
#
# Provision a NEW `worlds` DB on your PostgreSQL cluster (e.g. via a unix
# socket under <RUN_DIR>) with a dedicated role, then point
# WORLDS_PG_CONNECTION_STRING at it. The crate runs ./migrations on boot.

HTTP_SERVER_HOST=127.0.0.1
HTTP_SERVER_PORT=5141

# postgresql:///worlds?host=<RUN_DIR>&port=5433&user=<DB_USER>&password=<DB_PASSWORD>
WORLDS_PG_CONNECTION_STRING="postgresql:///worlds?host=<RUN_DIR>&port=5433&user=<DB_USER>&password=<DB_PASSWORD>"

# Public base URL of THIS server — used for scenesUrn baseUrl and the
# fixed-adapter signed-login URL in /about.
HTTP_BASE_URL="https://worlds.example.com"

# L1 chain id advertised in /about (mainnet = 1).
NETWORK_ID=1

# Optional space-separated global scene URNs.
# GLOBAL_SCENES_URN=""

# Catalyst content / lambdas public URLs reported by /about.
CONTENT_PUBLIC_URL="https://peer.decentraland.org/content"
LAMBDAS_PUBLIC_URL="https://peer.decentraland.org/lambdas"

# LiveKit token minting — devkey/devsecret mint parseable HS256 JWTs that a
# real LiveKit cluster will REJECT. Override for production.
LIVEKIT_HOST="<HOST>"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="devsecret"
LIVEKIT_WEBHOOK_KEY=""
MAX_USERS_PER_WORLD=100

# Phase 1: /contents reads are proxied to upstream with Range support.
CONTENTS_UPSTREAM_URL="https://worlds-content-server.decentraland.org"

RUST_LOG=catalyrst_worlds=info,tower_http=info
