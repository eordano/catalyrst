@compute @workgroup_size(256)
fn bc7_test_params_echo(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    out_words[gid] = params_word(gid);
}

// Sig kernel contract: blocks = block-major RGBA exactly as quantize_pack emits, 16 u32 words
// per block, one pixel per LE word (r | g<<8 | b<<16 | a<<24). Meta.n_items = num_blocks,
// Meta.total = num_groups = ceil(num_blocks / GROUP_WIDTH), one thread per GROUP of 4 blocks.
// out_words = one word per group: 2-bit class per block packed LSB-first in the low 8 bits,
// 0 Solid / 1 Alpha / 2 Opaque (host truncates each word to u8).
@group(0) @binding(4) var<storage, read> blocks: array<u32>;
@group(0) @binding(5) var<storage, read> plans: array<u32>;

const GROUP_WIDTH: u32 = 4u;
const CLASS_SOLID: u32 = 0u;
const CLASS_ALPHA: u32 = 1u;
const CLASS_OPAQUE: u32 = 2u;

fn block_from_words(base: u32, px: ptr<function, array<vec4<i32>, 16>>) {
    for (var i = 0u; i < 16u; i = i + 1u) {
        let w = blocks[base + i];
        (*px)[i] = vec4<i32>(
            i32(w & 0xffu),
            i32((w >> 8u) & 0xffu),
            i32((w >> 16u) & 0xffu),
            i32((w >> 24u) & 0xffu),
        );
    }
}

fn classify_block(px: ptr<function, array<vec4<i32>, 16>>) -> u32 {
    var lo = vec4<i32>(255, 255, 255, 255);
    var hi = vec4<i32>(0, 0, 0, 0);
    for (var i = 0u; i < 16u; i = i + 1u) {
        lo = min(lo, (*px)[i]);
        hi = max(hi, (*px)[i]);
    }
    if (all(lo == hi)) {
        return CLASS_SOLID;
    }
    if (lo.w < 255) {
        return CLASS_ALPHA;
    }
    return CLASS_OPAQUE;
}

fn group_signature(base_word: u32, n: u32) -> u32 {
    var sig = 0u;
    for (var k = 0u; k < n; k = k + 1u) {
        var px: array<vec4<i32>, 16>;
        block_from_words(base_word + k * 16u, &px);
        sig = sig | (classify_block(&px) << (k * 2u));
    }
    return sig;
}

@compute @workgroup_size(256)
fn bc7_group_sigs(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let start = gid * GROUP_WIDTH;
    var n = job.n_items - start;
    if (n > GROUP_WIDTH) {
        n = GROUP_WIDTH;
    }
    out_words[gid] = group_signature(start * 16u, n);
}

@compute @workgroup_size(256)
fn bc7_test_classify(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    var px: array<vec4<i32>, 16>;
    block_from_words(gid * 16u, &px);
    out_words[gid] = classify_block(&px);
}

// Math core contract: u64 travels as vec2<u32> (lo, hi). f32_to_u64 mirrors Rust
// `dist as i64 as u64` and is exact only for 0.0 <= f < 2^31 (host-side bound probe over
// adversarial inputs, see bc7-wgsl-03-mathcore evidence). shr64 requires 1 <= s <= 31.
// CCParams mirrors bc7.rs CCParams but carries sel_table (0/1/2 -> G_WEIGHTS2(X)/3(X)/4(X))
// instead of &'static slice refs; it is function-local only and never crosses a buffer.

fn add64(a: vec2<u32>, b: vec2<u32>) -> vec2<u32> {
    let lo = a.x + b.x;
    var hi = a.y + b.y;
    if (lo < a.x) {
        hi = hi + 1u;
    }
    return vec2<u32>(lo, hi);
}

fn lt64(a: vec2<u32>, b: vec2<u32>) -> bool {
    return a.y < b.y || (a.y == b.y && a.x < b.x);
}

fn le64(a: vec2<u32>, b: vec2<u32>) -> bool {
    return !lt64(b, a);
}

fn eq64(a: vec2<u32>, b: vec2<u32>) -> bool {
    return a.x == b.x && a.y == b.y;
}

fn sub64(a: vec2<u32>, b: vec2<u32>) -> vec2<u32> {
    let lo = a.x - b.x;
    var hi = a.y - b.y;
    if (a.x < b.x) {
        hi = hi - 1u;
    }
    return vec2<u32>(lo, hi);
}

fn saturating_add64(a: vec2<u32>, b: vec2<u32>) -> vec2<u32> {
    let s = add64(a, b);
    if (lt64(s, a)) {
        return vec2<u32>(0xffffffffu, 0xffffffffu);
    }
    return s;
}

fn mul32x32_64(a: u32, b: u32) -> vec2<u32> {
    let a0 = a & 0xffffu;
    let a1 = a >> 16u;
    let b0 = b & 0xffffu;
    let b1 = b >> 16u;
    let p00 = a0 * b0;
    let p01 = a0 * b1;
    let p10 = a1 * b0;
    let p11 = a1 * b1;
    let t = p10 + (p00 >> 16u);
    let t2 = p01 + (t & 0xffffu);
    let lo = (p00 & 0xffffu) | (t2 << 16u);
    let hi = p11 + (t >> 16u) + (t2 >> 16u);
    return vec2<u32>(lo, hi);
}

fn saturating_mul64(a: vec2<u32>, b: vec2<u32>) -> vec2<u32> {
    let ll = mul32x32_64(a.x, b.x);
    let lh = mul32x32_64(a.x, b.y);
    let hl = mul32x32_64(a.y, b.x);
    var over = (a.y != 0u && b.y != 0u) || (lh.y != 0u) || (hl.y != 0u);
    let mid = lh.x + hl.x;
    over = over || (mid < lh.x);
    let hi = ll.y + mid;
    over = over || (hi < mid);
    if (over) {
        return vec2<u32>(0xffffffffu, 0xffffffffu);
    }
    return vec2<u32>(ll.x, hi);
}

fn shr64(a: vec2<u32>, s: u32) -> vec2<u32> {
    return vec2<u32>((a.x >> s) | (a.y << (32u - s)), a.y >> s);
}

fn f32_to_u64(f: f32) -> vec2<u32> {
    return vec2<u32>(u32(f), 0u);
}

const YR_BITS: u32 = 0x3e59b3d0u;
const YG_BITS: u32 = 0x3f371759u;
const YB_BITS: u32 = 0x3d93dd98u;

fn fone() -> f32 {
    return bitcast<f32>(job.fone);
}

fn fzero() -> f32 {
    return (fone() - 1.0) * fone();
}

fn pmul(a: f32, b: f32) -> f32 {
    return ((a * b) - fzero()) * fone();
}

// padd/psub/pval: NVIDIA's Vulkan compiler was observed REASSOCIATING plain add/sub chains
// ((A+B)+C -> A+(B+C)) AND mul chains ((w*dl)*dl -> w*(dl*dl)) when intermediates are
// unobserved — beyond the FMA contraction pmul defeats. Any add/sub whose result feeds
// another add/sub must go through *fone (a mul is a hard boundary for add-trees), and any
// non-exact product whose result feeds another mul must go through -fzero (a sub is a hard
// boundary for mul-trees; *fone cannot pin mul grouping because exact 1.0 floats freely).
// fzero = (fone - 1.0) * fone is runtime +0.0 the compiler cannot fold; x - (+0.0) is an
// exact identity for every x including -0.0, and contracting either multiply into the sub
// (fma(a, b, -0)) is still a single correct rounding. fzero's trailing *fone is REQUIRED:
// a bare fone - 1.0 joins the consumer's add-tree and reassociates as (x - fone) + 1.0,
// which quantizes x near 1.0 (observed 3-ULP corruption in lsq iz terms). Exact-integer
// chains (products and sums < 2^24) are immune to regrouping and stay plain.
fn padd(a: f32, b: f32) -> f32 {
    return (a + b) * fone();
}

fn psub(a: f32, b: f32) -> f32 {
    return (a - b) * fone();
}

fn pval(x: f32) -> f32 {
    return x - fzero();
}

fn pmul3(a: f32, b: vec3<f32>) -> vec3<f32> {
    return ((a * b) - vec3<f32>(fzero())) * fone();
}

fn pmul4(a: f32, b: vec4<f32>) -> vec4<f32> {
    return ((a * b) - vec4<f32>(fzero())) * fone();
}

fn padd3(a: vec3<f32>, b: vec3<f32>) -> vec3<f32> {
    return (a + b) * fone();
}

fn padd4(a: vec4<f32>, b: vec4<f32>) -> vec4<f32> {
    return (a + b) * fone();
}

// recip_exact / sqrt_exact: correctly-rounded 1.0/x and sqrt(x) in integer mantissa math
// (Vulkan only guarantees ~2.5 ULP for FDiv/sqrt). Normal input with normal result is exact;
// subnormal/inf/nan (and subnormal results) fall back to hardware — unreachable for BC7 data.
fn recip_exact(x: f32) -> f32 {
    let bits = bitcast<u32>(x);
    let sgn = bits & 0x80000000u;
    let ex = (bits >> 23u) & 0xffu;
    if (ex == 0u || ex == 255u || ex >= 253u) {
        return 1.0 / x;
    }
    let m = (bits & 0x7fffffu) | 0x800000u;
    var q = 0u;
    var r = 1u;
    for (var i = 0u; i < 48u; i = i + 1u) {
        r = r << 1u;
        q = q << 1u;
        if (r >= m) {
            r = r - m;
            q = q + 1u;
        }
    }
    var mant: u32;
    var eb: i32;
    if (q == 0x2000000u) {
        mant = 0x800000u;
        eb = 254 - i32(ex);
    } else {
        mant = q >> 1u;
        eb = 253 - i32(ex);
        if ((q & 1u) == 1u && (r != 0u || (mant & 1u) == 1u)) {
            mant = mant + 1u;
            if (mant == 0x1000000u) {
                mant = 0x800000u;
                eb = eb + 1;
            }
        }
    }
    if (eb <= 0) {
        return 1.0 / x;
    }
    return bitcast<f32>(sgn | (u32(eb) << 23u) | (mant & 0x7fffffu));
}

fn isqrt49(n: vec2<u32>) -> vec2<u32> {
    var num = n;
    var res = vec2<u32>(0u, 0u);
    var bit = vec2<u32>(0u, 0x10000u);
    loop {
        if (le64(bit, num) || (bit.x == 0u && bit.y == 0u)) {
            break;
        }
        bit = shr64(bit, 2u);
    }
    loop {
        if (bit.x == 0u && bit.y == 0u) {
            break;
        }
        let rb = add64(res, bit);
        if (le64(rb, num)) {
            num = sub64(num, rb);
            res = add64(shr64(res, 1u), bit);
        } else {
            res = shr64(res, 1u);
        }
        bit = shr64(bit, 2u);
    }
    return vec2<u32>(res.x, num.x | num.y);
}

fn sqrt_exact(x: f32) -> f32 {
    let bits = bitcast<u32>(x);
    let ex = (bits >> 23u) & 0xffu;
    if (bits >= 0x7f800000u || ex == 0u) {
        return sqrt(x);
    }
    let m = (bits & 0x7fffffu) | 0x800000u;
    let e = i32(ex) - 127;
    var g: u32;
    var h: i32;
    if ((e & 1) == 0) {
        g = m;
        h = e / 2;
    } else {
        g = m << 1u;
        h = (e - 1) / 2;
    }
    let sr = isqrt49(vec2<u32>(g << 25u, g >> 7u));
    var mant = sr.x >> 1u;
    var eb = h + 127;
    if ((sr.x & 1u) == 1u && (sr.y != 0u || (mant & 1u) == 1u)) {
        mant = mant + 1u;
        if (mant == 0x1000000u) {
            mant = 0x800000u;
            eb = eb + 1;
        }
    }
    return bitcast<f32>((u32(eb) << 23u) | (mant & 0x7fffffu));
}

fn fsaturate(v: f32) -> f32 {
    return clamp(v, 0.0, 1.0);
}

// itrunc mirrors Rust `f as i32`: truncation with saturation at the i32 range ends.
fn itrunc(f: f32) -> i32 {
    if (f >= 2147483648.0) {
        return 2147483647;
    }
    if (f < -2147483648.0) {
        return bitcast<i32>(0x80000000u);
    }
    return i32(f);
}

fn iabs32(v: i32) -> i32 {
    return abs(v);
}

fn sq(s: f32) -> f32 {
    return s * s;
}

fn vec4f_dot(a: vec4<f32>, b: vec4<f32>) -> f32 {
    return padd(padd(padd(pmul(a.x, b.x), pmul(a.y, b.y)), pmul(a.z, b.z)), pmul(a.w, b.w));
}

fn vec4f_normalize(v: vec4<f32>) -> vec4<f32> {
    let s = padd(padd(padd(pmul(v.x, v.x), pmul(v.y, v.y)), pmul(v.z, v.z)), pmul(v.w, v.w));
    if (s != 0.0) {
        let inv = recip_exact(sqrt_exact(s));
        return vec4<f32>(v.x * inv, v.y * inv, v.z * inv, v.w * inv);
    }
    return v;
}

struct CCParams {
    num_selector_weights: u32,
    sel_table: u32,
    comp_bits: u32,
    weights: vec4<u32>,
    has_alpha: bool,
    has_pbits: bool,
    endpoints_share_pbit: bool,
    perceptual: bool,
}

fn ccparams_clear() -> CCParams {
    var p: CCParams;
    p.num_selector_weights = 0u;
    p.sel_table = 0u;
    p.comp_bits = 0u;
    p.weights = vec4<u32>(1u, 1u, 1u, 1u);
    p.has_alpha = false;
    p.has_pbits = false;
    p.endpoints_share_pbit = false;
    p.perceptual = false;
    return p;
}

fn psel_weight(tbl: u32, i: u32) -> u32 {
    if (tbl == 0u) {
        return G_WEIGHTS2[i];
    }
    if (tbl == 1u) {
        return G_WEIGHTS3[i];
    }
    return G_WEIGHTS4[i];
}

fn psel_weightx(tbl: u32, i: u32) -> vec4<f32> {
    if (tbl == 0u) {
        return vec4<f32>(weights2x(i, 0u), weights2x(i, 1u), weights2x(i, 2u), weights2x(i, 3u));
    }
    if (tbl == 1u) {
        return vec4<f32>(weights3x(i, 0u), weights3x(i, 1u), weights3x(i, 2u), weights3x(i, 3u));
    }
    return vec4<f32>(weights4x(i, 0u), weights4x(i, 1u), weights4x(i, 2u), weights4x(i, 3u));
}

fn scale_color(c: vec4<i32>, p: CCParams) -> vec4<i32> {
    let n = p.comp_bits + select(0u, 1u, p.has_pbits);
    var v = bitcast<vec4<u32>>(c) << vec4<u32>(8u - n);
    v = v | (v >> vec4<u32>(n));
    return bitcast<vec4<i32>>(v);
}

fn luma_f(e: vec4<i32>) -> f32 {
    return padd(
        padd(
            pmul(f32(e.x), bitcast<f32>(YR_BITS)),
            pmul(f32(e.y), bitcast<f32>(YG_BITS)),
        ),
        pmul(f32(e.z), bitcast<f32>(YB_BITS)),
    );
}

fn compute_color_distance_rgb(e1: vec4<i32>, e2: vec4<i32>, perceptual: bool, w: vec4<u32>) -> vec2<u32> {
    if (perceptual) {
        let l1 = luma_f(e1);
        let cr1 = psub(f32(e1.x), l1);
        let cb1 = psub(f32(e1.z), l1);
        let l2 = luma_f(e2);
        let cr2 = psub(f32(e2.x), l2);
        let cb2 = psub(f32(e2.z), l2);
        let dl = psub(l1, l2);
        let dcr = psub(cr1, cr2);
        let dcb = psub(cb1, cb2);
        let d = padd(
            padd(
                pmul(f32(w.x), pval(dl * dl)),
                pmul(pval(f32(w.y) * pr_weight()), pval(dcr * dcr)),
            ),
            pmul(pval(f32(w.z) * pb_weight()), pval(dcb * dcb)),
        );
        return f32_to_u64(d);
    }
    let dr = psub(f32(e1.x), f32(e2.x));
    let dg = psub(f32(e1.y), f32(e2.y));
    let db = psub(f32(e1.z), f32(e2.z));
    let d = padd(
        padd(pmul(f32(w.x) * dr, dr), pmul(f32(w.y) * dg, dg)),
        pmul(f32(w.z) * db, db),
    );
    return f32_to_u64(d);
}

fn compute_color_distance_rgba(e1: vec4<i32>, e2: vec4<i32>, perceptual: bool, w: vec4<u32>) -> vec2<u32> {
    let da = psub(f32(e1.w), f32(e2.w));
    let a_err = pmul(f32(w.w), da * da);
    if (perceptual) {
        let l1 = luma_f(e1);
        let cr1 = psub(f32(e1.x), l1);
        let cb1 = psub(f32(e1.z), l1);
        let l2 = luma_f(e2);
        let cr2 = psub(f32(e2.x), l2);
        let cb2 = psub(f32(e2.z), l2);
        let dl = psub(l1, l2);
        let dcr = psub(cr1, cr2);
        let dcb = psub(cb1, cb2);
        let d = padd(
            padd(
                padd(
                    pmul(f32(w.x), pval(dl * dl)),
                    pmul(pval(f32(w.y) * pr_weight()), pval(dcr * dcr)),
                ),
                pmul(pval(f32(w.z) * pb_weight()), pval(dcb * dcb)),
            ),
            a_err,
        );
        return f32_to_u64(d);
    }
    let dr = psub(f32(e1.x), f32(e2.x));
    let dg = psub(f32(e1.y), f32(e2.y));
    let db = psub(f32(e1.z), f32(e2.z));
    let d = padd(
        padd(
            padd(pmul(f32(w.x) * dr, dr), pmul(f32(w.y) * dg, dg)),
            pmul(f32(w.z) * db, db),
        ),
        a_err,
    );
    return f32_to_u64(d);
}

fn compute_lsq_endpoints_rgba(
    n: u32,
    sel: ptr<function, array<i32, 16>>,
    tbl: u32,
    xl: ptr<function, vec4<f32>>,
    xh: ptr<function, vec4<f32>>,
    colors: ptr<function, array<vec4<i32>, 16>>,
) {
    var z00 = 0.0;
    var z10 = 0.0;
    var z11 = 0.0;
    var q00 = vec4<f32>(0.0);
    var t = vec4<f32>(0.0);
    for (var i = 0u; i < n; i = i + 1u) {
        let s = u32((*sel)[i]);
        let swv = psel_weightx(tbl, s);
        z00 = padd(z00, swv.x);
        z10 = padd(z10, swv.y);
        z11 = padd(z11, swv.z);
        let cf = vec4<f32>((*colors)[i]);
        q00 = padd4(q00, pmul4(swv.w, cf));
        t = padd4(t, cf);
    }
    let q10 = t - q00;
    let z01 = z10;
    var det = pmul(z00, z11) - pmul(z01, z10);
    if (det != 0.0) {
        det = recip_exact(det);
    }
    let iz00 = pval(z11 * det);
    let iz01 = pval(-z01 * det);
    let iz10 = pval(-z10 * det);
    let iz11 = pval(z00 * det);
    *xl = pmul4(iz00, q00) + pmul4(iz01, q10);
    *xh = pmul4(iz10, q00) + pmul4(iz11, q10);
}

fn compute_lsq_endpoints_rgb(
    n: u32,
    sel: ptr<function, array<i32, 16>>,
    tbl: u32,
    xl: ptr<function, vec4<f32>>,
    xh: ptr<function, vec4<f32>>,
    colors: ptr<function, array<vec4<i32>, 16>>,
) {
    var z00 = 0.0;
    var z10 = 0.0;
    var z11 = 0.0;
    var q00 = vec3<f32>(0.0);
    var t = vec3<f32>(0.0);
    for (var i = 0u; i < n; i = i + 1u) {
        let s = u32((*sel)[i]);
        let swv = psel_weightx(tbl, s);
        z00 = padd(z00, swv.x);
        z10 = padd(z10, swv.y);
        z11 = padd(z11, swv.z);
        let c = (*colors)[i];
        let cf = vec3<f32>(f32(c.x), f32(c.y), f32(c.z));
        q00 = padd3(q00, pmul3(swv.w, cf));
        t = padd3(t, cf);
    }
    let q10 = t - q00;
    let z01 = z10;
    var det = pmul(z00, z11) - pmul(z01, z10);
    if (det != 0.0) {
        det = recip_exact(det);
    }
    let iz00 = pval(z11 * det);
    let iz01 = pval(-z01 * det);
    let iz10 = pval(-z10 * det);
    let iz11 = pval(z00 * det);
    let lo = pmul3(iz00, q00) + pmul3(iz01, q10);
    let hi = pmul3(iz10, q00) + pmul3(iz11, q10);
    *xl = vec4<f32>(lo, (*xl).w);
    *xh = vec4<f32>(hi, (*xh).w);
}

fn compute_lsq_endpoints_a(
    n: u32,
    sel: ptr<function, array<i32, 16>>,
    tbl: u32,
    xl: ptr<function, f32>,
    xh: ptr<function, f32>,
    colors: ptr<function, array<vec4<i32>, 16>>,
) {
    var z00 = 0.0;
    var z10 = 0.0;
    var z11 = 0.0;
    var q00 = 0.0;
    var t = 0.0;
    for (var i = 0u; i < n; i = i + 1u) {
        let s = u32((*sel)[i]);
        let swv = psel_weightx(tbl, s);
        z00 = padd(z00, swv.x);
        z10 = padd(z10, swv.y);
        z11 = padd(z11, swv.z);
        q00 = padd(q00, pmul(swv.w, f32((*colors)[i].w)));
        t = padd(t, f32((*colors)[i].w));
    }
    let q10 = t - q00;
    let z01 = z10;
    var det = pmul(z00, z11) - pmul(z01, z10);
    if (det != 0.0) {
        det = recip_exact(det);
    }
    let iz00 = pval(z11 * det);
    let iz01 = pval(-z01 * det);
    let iz10 = pval(-z10 * det);
    let iz11 = pval(z00 * det);
    *xl = pmul(iz00, q00) + pmul(iz01, q10);
    *xh = pmul(iz10, q00) + pmul(iz11, q10);
}

// Math-core test entries. blocks(@binding 4) doubles as a generic packed word stream:
// u64ops in-stride 6 (a.lo a.hi b.lo b.hi f_bits shift), out-stride 12;
// vecmath in-stride 16 (v[4] a[4] c[4] comp_bits has_pbits f_bits x), out-stride 16;
// dist in-stride 16 (e1[4] e2[4] w[4] perceptual pad[3]), out-stride 2 (u64 lo,hi);
// lsq in-stride 84 (n tbl pad[2] sel[16] colors[64]), out-stride 8 (rgba/rgb) or 2 (a).
@compute @workgroup_size(256)
fn bc7_test_u64ops(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * 6u;
    let a = vec2<u32>(blocks[ib], blocks[ib + 1u]);
    let b = vec2<u32>(blocks[ib + 2u], blocks[ib + 3u]);
    let f = bitcast<f32>(blocks[ib + 4u]);
    let sh = blocks[ib + 5u];
    let ob = gid * 12u;
    let s = add64(a, b);
    out_words[ob] = s.x;
    out_words[ob + 1u] = s.y;
    let sa = saturating_add64(a, b);
    out_words[ob + 2u] = sa.x;
    out_words[ob + 3u] = sa.y;
    let sm = saturating_mul64(a, b);
    out_words[ob + 4u] = sm.x;
    out_words[ob + 5u] = sm.y;
    let m = mul32x32_64(a.x, b.x);
    out_words[ob + 6u] = m.x;
    out_words[ob + 7u] = m.y;
    var flags = 0u;
    if (lt64(a, b)) {
        flags = flags | 1u;
    }
    if (le64(a, b)) {
        flags = flags | 2u;
    }
    if (eq64(a, b)) {
        flags = flags | 4u;
    }
    out_words[ob + 8u] = flags;
    let sr = shr64(a, sh);
    out_words[ob + 9u] = sr.x;
    out_words[ob + 10u] = sr.y;
    out_words[ob + 11u] = f32_to_u64(f).x;
}

fn in_vec4f(off: u32) -> vec4<f32> {
    return vec4<f32>(
        bitcast<f32>(blocks[off]),
        bitcast<f32>(blocks[off + 1u]),
        bitcast<f32>(blocks[off + 2u]),
        bitcast<f32>(blocks[off + 3u]),
    );
}

fn in_vec4i(off: u32) -> vec4<i32> {
    return vec4<i32>(
        i32(blocks[off]),
        i32(blocks[off + 1u]),
        i32(blocks[off + 2u]),
        i32(blocks[off + 3u]),
    );
}

@compute @workgroup_size(256)
fn bc7_test_vecmath(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * 16u;
    let v = in_vec4f(ib);
    let a = in_vec4f(ib + 4u);
    let c = in_vec4i(ib + 8u);
    var p = ccparams_clear();
    p.comp_bits = blocks[ib + 12u];
    p.has_pbits = blocks[ib + 13u] != 0u;
    let f = bitcast<f32>(blocks[ib + 14u]);
    let x = i32(blocks[ib + 15u]);
    let ob = gid * 16u;
    let nv = vec4f_normalize(v);
    out_words[ob] = bitcast<u32>(nv.x);
    out_words[ob + 1u] = bitcast<u32>(nv.y);
    out_words[ob + 2u] = bitcast<u32>(nv.z);
    out_words[ob + 3u] = bitcast<u32>(nv.w);
    out_words[ob + 4u] = bitcast<u32>(vec4f_dot(v, a));
    let sc = scale_color(c, p);
    out_words[ob + 5u] = bitcast<u32>(sc.x);
    out_words[ob + 6u] = bitcast<u32>(sc.y);
    out_words[ob + 7u] = bitcast<u32>(sc.z);
    out_words[ob + 8u] = bitcast<u32>(sc.w);
    out_words[ob + 9u] = bitcast<u32>(fsaturate(f));
    out_words[ob + 10u] = bitcast<u32>(itrunc(f));
    out_words[ob + 11u] = bitcast<u32>(iabs32(x));
    out_words[ob + 12u] = bitcast<u32>(sq(f));
    out_words[ob + 13u] = psel_weight(blocks[ib + 12u] % 3u, blocks[ib + 13u] % 4u);
    var rec = 0u;
    var sqx = 0u;
    if (f != 0.0) {
        rec = bitcast<u32>(recip_exact(f));
        sqx = bitcast<u32>(sqrt_exact(abs(f)));
    }
    out_words[ob + 14u] = rec;
    out_words[ob + 15u] = sqx;
}

@compute @workgroup_size(256)
fn bc7_test_dist_rgb(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * 16u;
    let e1 = in_vec4i(ib);
    let e2 = in_vec4i(ib + 4u);
    let w = vec4<u32>(blocks[ib + 8u], blocks[ib + 9u], blocks[ib + 10u], blocks[ib + 11u]);
    let perc = blocks[ib + 12u] != 0u;
    let d = compute_color_distance_rgb(e1, e2, perc, w);
    out_words[gid * 2u] = d.x;
    out_words[gid * 2u + 1u] = d.y;
}

