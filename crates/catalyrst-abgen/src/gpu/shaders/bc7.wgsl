const CONST_DUMP_WORDS: u32 = 9490u;

fn const_word_small(i: u32) -> u32 {
    if (i < 4u) { let j = i - 0u; return G_WEIGHTS2[j]; }
    if (i < 12u) { let j = i - 4u; return G_WEIGHTS3[j]; }
    if (i < 28u) { let j = i - 12u; return G_WEIGHTS4[j]; }
    if (i < 44u) { let j = i - 28u; return bitcast<u32>(weights2x(j / 4u, j % 4u)); }
    if (i < 76u) { let j = i - 44u; return bitcast<u32>(weights3x(j / 4u, j % 4u)); }
    if (i < 140u) { let j = i - 76u; return bitcast<u32>(weights4x(j / 4u, j % 4u)); }
    if (i < 2188u) { return 0u; }
    if (i < 2252u) { let j = i - 2188u; return bitcast<u32>(G_ANCHOR_2ND[j]); }
    if (i < 2316u) { let j = i - 2252u; return bitcast<u32>(G_ANCHOR_3RD_1[j]); }
    if (i < 2380u) { let j = i - 2316u; return bitcast<u32>(G_ANCHOR_3RD_2[j]); }
    if (i < 2388u) { let j = i - 2380u; return G_NUM_SUBSETS[j]; }
    if (i < 2396u) { let j = i - 2388u; return G_PARTITION_BITS[j]; }
    if (i < 2404u) { let j = i - 2396u; return G_COLOR_INDEX_BITCOUNT[j]; }
    if (i < 2412u) { let j = i - 2404u; return bitcast<u32>(G_ALPHA_INDEX_BITCOUNT[j]); }
    if (i < 2420u) { let j = i - 2412u; return bitcast<u32>(G_MODE_HAS_P_BITS[j]); }
    if (i < 2428u) { let j = i - 2420u; return bitcast<u32>(G_MODE_HAS_SHARED_P_BITS[j]); }
    if (i < 2436u) { let j = i - 2428u; return G_COLOR_PRECISION_TABLE[j]; }
    if (i < 2444u) { let j = i - 2436u; return G_ALPHA_PRECISION_TABLE[j]; }
    if (i < 2445u) { return bitcast<u32>(pr_weight()); }
    if (i < 2446u) { return bitcast<u32>(pb_weight()); }
    if (i < 2453u) { let j = i - 2446u; return mode_idx_word(j); }
    if (i < 2454u) { return BC7E_2SUBSET_CHECKERBOARD_PARTITION_INDEX; }
    if (i < 8982u) { return 0u; }
    let j = i - 8982u;
    return tree_word(j);
}

fn const_word_priv1(i: u32) -> u32 {
    if (i >= 140u && i < 1164u) { return G_PARTITION2[i - 140u]; }
    if (i >= 1164u && i < 2188u) { return G_PARTITION3[i - 1164u]; }
    if (i >= 5526u && i < 5718u) { return SUBSET_IDX2_TOTAL[i - 5526u]; }
    if (i >= 8790u && i < 8982u) { return SUBSET_IDX3_TOTAL[i - 8790u]; }
    return 0u;
}

fn const_word_priv2(i: u32) -> u32 {
    if (i >= 2454u && i < 5526u) { return bitcast<u32>(SUBSET_IDX2_IDX[i - 2454u]); }
    if (i >= 5718u && i < 8790u) { return bitcast<u32>(SUBSET_IDX3_IDX[i - 5718u]); }
    return 0u;
}

fn weights2x(i: u32, c: u32) -> f32 {
    return bitcast<f32>(G_WEIGHTS2X_BITS[i * 4u + c]);
}

fn weights3x(i: u32, c: u32) -> f32 {
    return bitcast<f32>(G_WEIGHTS3X_BITS[i * 4u + c]);
}

fn weights4x(i: u32, c: u32) -> f32 {
    return bitcast<f32>(G_WEIGHTS4X_BITS[i * 4u + c]);
}

fn pr_weight() -> f32 {
    return bitcast<f32>(PR_WEIGHT_BITS);
}

fn pb_weight() -> f32 {
    return bitcast<f32>(PB_WEIGHT_BITS);
}

fn mode_idx_word(j: u32) -> u32 {
    if (j == 0u) { return MODE0_IDX; }
    if (j == 1u) { return MODE1_IDX; }
    if (j == 2u) { return MODE6_IDX; }
    if (j == 3u) { return MODE5_IDX; }
    if (j == 4u) { return MODE4_IDX3; }
    if (j == 5u) { return MODE4_IDX2; }
    return MODE7_IDX;
}

fn tree_word(j: u32) -> u32 {
    let n = j / 4u;
    let f = j % 4u;
    if (f == 0u) { return bitcast<u32>(TREE_FEATURE[n]); }
    if (f == 1u) { return bitcast<u32>(TREE_THRESHOLD[n]); }
    if (f == 2u) { return bitcast<u32>(TREE_LEFT[n]); }
    return bitcast<u32>(TREE_RIGHT[n]);
}

fn params_word(i: u32) -> u32 {
    if (i < 8u) { return params.max_partitions_mode[i]; }
    if (i < 12u) { return params.weights[i - 8u]; }
    if (i == 12u) { return params.uber_level; }
    if (i == 13u) { return params.refinement_passes; }
    if (i == 14u) { return params.mode4_rotation_mask; }
    if (i == 15u) { return params.mode4_index_mask; }
    if (i == 16u) { return params.mode5_rotation_mask; }
    if (i == 17u) { return params.uber1_mask; }
    if (i == 18u) { return params.perceptual; }
    if (i == 19u) { return params.pbit_search; }
    if (i == 20u) { return params.mode6_only; }
    if (i == 21u) { return params.op_max_mode13; }
    if (i == 22u) { return params.op_max_mode0; }
    if (i == 23u) { return params.op_max_mode2; }
    if (i < 31u) { return params.use_mode[i - 24u]; }
    if (i == 31u) { return params.al_max_mode7; }
    if (i < 36u) { return params.mode67_weight_mul[i - 32u]; }
    if (i == 36u) { return params.use_mode4; }
    if (i == 37u) { return params.use_mode5; }
    if (i == 38u) { return params.use_mode6; }
    if (i == 39u) { return params.use_mode7; }
    if (i == 40u) { return params.use_mode4_rotation; }
    return params.use_mode5_rotation;
}

// Test entries: dump every const table word (+ echo the bound OptTables words) and echo
// every ParamsGpu field, so the host can verify layout + values bit-exactly.
@compute @workgroup_size(256)
fn bc7_test_tables(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    if (gid < CONST_DUMP_WORDS) {
        out_words[gid] = const_word_small(gid);
    } else {
        out_words[gid] = opt_tables[gid - CONST_DUMP_WORDS];
    }
}

// The six big dynamically-indexed tables are var<private> (naga copies a const array
// into a fresh function-local at every dynamically-indexed use site, which explodes
// under inlining); an entry referencing all six at once (~34KB of per-thread init)
// ICEs the NVIDIA 590.48.01 compiler, so the table dump is split into three entries
// with disjoint table sets, OR-merged by the host.
@compute @workgroup_size(256)
fn bc7_test_tables_priv1(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    if (gid < CONST_DUMP_WORDS) {
        out_words[gid] = const_word_priv1(gid);
    } else {
        out_words[gid] = 0u;
    }
}

@compute @workgroup_size(256)
fn bc7_test_tables_priv2(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
