fn fix_degenerate_endpoints(
    mode: u32,
    tmin: ptr<function, vec4<i32>>,
    tmax: ptr<function, vec4<i32>>,
    xl: vec4<f32>,
    xh: vec4<f32>,
    iscale: i32,
) {
    if (mode == 1u || mode == 4u) {
        for (var i = 0u; i < 3u; i = i + 1u) {
            if ((*tmin)[i] == (*tmax)[i] && abs(xl[i] - xh[i]) > 0.0) {
                if ((*tmin)[i] > (iscale >> 1u)) {
                    if ((*tmin)[i] > 0) {
                        (*tmin)[i] = (*tmin)[i] - 1;
                    } else if ((*tmax)[i] < iscale) {
                        (*tmax)[i] = (*tmax)[i] + 1;
                    }
                } else if ((*tmax)[i] < iscale) {
                    (*tmax)[i] = (*tmax)[i] + 1;
                } else if ((*tmin)[i] > 0) {
                    (*tmin)[i] = (*tmin)[i] - 1;
                }
                if (mode == 4u) {
                    if ((*tmin)[i] > (iscale >> 1u)) {
                        if ((*tmax)[i] < iscale) {
                            (*tmax)[i] = (*tmax)[i] + 1;
                        } else if ((*tmin)[i] > 0) {
                            (*tmin)[i] = (*tmin)[i] - 1;
                        }
                    } else if ((*tmin)[i] > 0) {
                        (*tmin)[i] = (*tmin)[i] - 1;
                    } else if ((*tmax)[i] < iscale) {
                        (*tmax)[i] = (*tmax)[i] + 1;
                    }
                }
            }
        }
    }
}

fn eval_solution_n16_rgb_scalar(
    num_pixels: u32,
    pixels: ptr<function, array<vec4<i32>, 16>>,
    wc: ptr<function, array<vec4<f32>, 16>>,
    w3: vec3<f32>,
    d3: vec3<f32>,
    l3: vec3<f32>,
    f: f32,
    n: u32,
    selectors_temp: ptr<function, array<i32, 16>>,
) -> f32 {
    var total_errf = 0.0;
    for (var i = 0u; i < num_pixels; i = i + 1u) {
        let r = f32((*pixels)[i].x);
        let g = f32((*pixels)[i].y);
        let b = f32((*pixels)[i].z);
        let s = (pmul(r, d3.x) + l3.x) + (pmul(g, d3.y) + l3.y) + (pmul(b, d3.z) + l3.z);
        let raw = pmul(s, f) + 0.5;
        var i0 = 0;
        var i1 = 0;
        if (raw == raw) {
            let bs = clamp(floor(raw), 1.0, f32(n - 1u));
            i0 = itrunc(bs - 1.0);
            i1 = itrunc(bs);
        }
        let c0 = (*wc)[u32(i0)];
        let dr0 = c0.x - r;
        let dg0 = c0.y - g;
        let db0 = c0.z - b;
        let err0 = padd(
            padd(pmul(w3.x * dr0, dr0), pmul(w3.y * dg0, dg0)),
            pmul(w3.z * db0, db0),
        );
        let c1 = (*wc)[u32(i1)];
        let dr1 = c1.x - r;
        let dg1 = c1.y - g;
        let db1 = c1.z - b;
        let err1 = padd(
            padd(pmul(w3.x * dr1, dr1), pmul(w3.y * dg1, dg1)),
            pmul(w3.z * db1, db1),
        );
        let min_err = min(err0, err1);
        total_errf = padd(total_errf, min_err);
        (*selectors_temp)[i] = select(i1, i0, min_err == err0);
    }
    return total_errf;
}

fn evaluate_solution(
    low: vec4<i32>,
    high: vec4<i32>,
    pbits: vec2<u32>,
    p: CCParams,
    res: ptr<function, CCResults>,
    num_pixels: u32,
    pixels: ptr<function, array<vec4<i32>, 16>>,
) -> vec2<u32> {
    var qmin = low;
    var qmax = high;
    if (p.has_pbits) {
        var max_pbit = pbits.y;
        if (p.endpoints_share_pbit) {
            max_pbit = pbits.x;
        }
        qmin = (low << vec4<u32>(1u)) | vec4<i32>(i32(pbits.x));
        qmax = (high << vec4<u32>(1u)) | vec4<i32>(i32(max_pbit));
    }
    let amin = scale_color(qmin, p);
    let amax = scale_color(qmax, p);
    let n = p.num_selector_weights;
    var nc = 3u;
    if (p.has_alpha) {
        nc = 4u;
    }
    var total_errf = 0.0;
    let wr = f32(p.weights.x);
    let wg = f32(p.weights.y);
    let wb = f32(p.weights.z);
    let wa = f32(p.weights.w);
    var wc: array<vec4<f32>, 16>;
    wc[0] = vec4<f32>(amin);
    wc[n - 1u] = vec4<f32>(amax);
    for (var i = 1u; i < n - 1u; i = i + 1u) {
        let wf = f32(psel_weight(p.sel_table, i));
        for (var j = 0u; j < nc; j = j + 1u) {
            wc[i][j] = floor((pmul(wc[0u][j], 64.0 - wf) + pmul(wc[n - 1u][j], wf) + 32.0) * 0.015625);
        }
    }
    if (!p.perceptual) {
        if (!p.has_alpha) {
            if (n == 16u) {
                let lr0 = f32(amin.x);
                let lg0 = f32(amin.y);
                let lb0 = f32(amin.z);
                let dr = f32(amax.x) - lr0;
                let dg = f32(amax.y) - lg0;
                let db = f32(amax.z) - lb0;
                let f = f32(n) * recip_exact(pmul(dr, dr) + pmul(dg, dg) + pmul(db, db));
                let lr = pmul(lr0, -dr);
                let lg = pmul(lg0, -dg);
                let lb = pmul(lb0, -db);
                var seltmp: array<i32, 16>;
                total_errf = eval_solution_n16_rgb_scalar(
                    num_pixels,
                    pixels,
                    &wc,
                    vec3<f32>(wr, wg, wb),
                    vec3<f32>(dr, dg, db),
                    vec3<f32>(lr, lg, lb),
                    f,
                    n,
                    &seltmp,
                );
                for (var i = 0u; i < num_pixels; i = i + 1u) {
                    (*res).selectors_temp[i] = seltmp[i];
                }
            } else {
                for (var i = 0u; i < num_pixels; i = i + 1u) {
                    let pr = f32((*pixels)[i].x);
                    let pg = f32((*pixels)[i].y);
                    let pb = f32((*pixels)[i].z);
                    var errs: array<f32, 4>;
                    for (var k = 0u; k < 4u; k = k + 1u) {
                        let d0 = wc[k].x - pr;
                        let d1 = wc[k].y - pg;
                        let d2 = wc[k].z - pb;
                        errs[k] = padd(
                            padd(pmul(wr * d0, d0), pmul(wg * d1, d1)),
                            pmul(wb * d2, d2),
                        );
                    }
                    var best_err = min(min(min(errs[0], errs[1]), errs[2]), errs[3]);
                    var best_sel = 0;
                    if (best_err == errs[1]) {
                        best_sel = 1;
                    }
                    if (best_err == errs[2]) {
                        best_sel = 2;
                    }
                    if (best_err == errs[3]) {
                        best_sel = 3;
                    }
                    if (n == 8u) {
                        var e2: array<f32, 4>;
                        for (var k = 0u; k < 4u; k = k + 1u) {
                            let d0 = wc[4u + k].x - pr;
                            let d1 = wc[4u + k].y - pg;
                            let d2 = wc[4u + k].z - pb;
                            e2[k] = padd(
                                padd(pmul(wr * d0, d0), pmul(wg * d1, d1)),
                                pmul(wb * d2, d2),
                            );
                        }
                        best_err = min(best_err, min(min(min(e2[0], e2[1]), e2[2]), e2[3]));
                        if (best_err == e2[0]) {
                            best_sel = 4;
                        }
                        if (best_err == e2[1]) {
                            best_sel = 5;
                        }
                        if (best_err == e2[2]) {
                            best_sel = 6;
                        }
                        if (best_err == e2[3]) {
                            best_sel = 7;
                        }
                    }
                    total_errf = padd(total_errf, best_err);
                    (*res).selectors_temp[i] = best_sel;
                }
            }
        } else {
            if (n == 16u) {
                let lr0 = f32(amin.x);
                let lg0 = f32(amin.y);
                let lb0 = f32(amin.z);
                let la0 = f32(amin.w);
                let dr = f32(amax.x) - lr0;
                let dg = f32(amax.y) - lg0;
                let db = f32(amax.z) - lb0;
                let da = f32(amax.w) - la0;
                let f = f32(n) * recip_exact(pmul(dr, dr) + pmul(dg, dg) + pmul(db, db) + pmul(da, da));
                let lr = pmul(lr0, -dr);
                let lg = pmul(lg0, -dg);
                let lb = pmul(lb0, -db);
                let la = pmul(la0, -da);
                for (var i = 0u; i < num_pixels; i = i + 1u) {
                    let r = f32((*pixels)[i].x);
                    let g = f32((*pixels)[i].y);
                    let b = f32((*pixels)[i].z);
                    let a = f32((*pixels)[i].w);
                    let s = (pmul(r, dr) + lr) + (pmul(g, dg) + lg) + (pmul(b, db) + lb)
                        + (pmul(a, da) + la);
                    let raw = pmul(s, f) + 0.5;
                    var i0 = 0;
                    var i1 = 0;
                    if (raw == raw) {
                        let bs = clamp(floor(raw), 1.0, f32(n - 1u));
                        i0 = itrunc(bs - 1.0);
                        i1 = itrunc(bs);
                    }
                    let c0 = wc[u32(i0)];
                    let dr0 = c0.x - r;
                    let dg0 = c0.y - g;
                    let db0 = c0.z - b;
                    let da0 = c0.w - a;
                    let err0 = padd(
                        padd(
                            padd(pmul(wr * dr0, dr0), pmul(wg * dg0, dg0)),
                            pmul(wb * db0, db0),
                        ),
                        pmul(wa * da0, da0),
                    );
                    let c1 = wc[u32(i1)];
                    let dr1 = c1.x - r;
                    let dg1 = c1.y - g;
                    let db1 = c1.z - b;
                    let da1 = c1.w - a;
                    let err1 = padd(
                        padd(
                            padd(pmul(wr * dr1, dr1), pmul(wg * dg1, dg1)),
                            pmul(wb * db1, db1),
                        ),
                        pmul(wa * da1, da1),
                    );
                    let min_err = min(err0, err1);
                    total_errf = padd(total_errf, min_err);
                    (*res).selectors_temp[i] = select(i1, i0, min_err == err0);
                }
            } else {
                for (var i = 0u; i < num_pixels; i = i + 1u) {
                    let pr = f32((*pixels)[i].x);
                    let pg = f32((*pixels)[i].y);
                    let pb = f32((*pixels)[i].z);
                    let pa = f32((*pixels)[i].w);
                    var errs: array<f32, 4>;
                    for (var k = 0u; k < 4u; k = k + 1u) {
                        let d0 = wc[k].x - pr;
                        let d1 = wc[k].y - pg;
                        let d2 = wc[k].z - pb;
                        let d3 = wc[k].w - pa;
                        errs[k] = padd(
                            padd(
                                padd(pmul(wr * d0, d0), pmul(wg * d1, d1)),
                                pmul(wb * d2, d2),
                            ),
                            pmul(wa * d3, d3),
                        );
                    }
                    var best_err = min(min(min(errs[0], errs[1]), errs[2]), errs[3]);
                    var best_sel = 0;
                    if (best_err == errs[1]) {
                        best_sel = 1;
                    }
                    if (best_err == errs[2]) {
                        best_sel = 2;
                    }
                    if (best_err == errs[3]) {
                        best_sel = 3;
                    }
                    if (n == 8u) {
                        var e2: array<f32, 4>;
                        for (var k = 0u; k < 4u; k = k + 1u) {
                            let d0 = wc[4u + k].x - pr;
                            let d1 = wc[4u + k].y - pg;
                            let d2 = wc[4u + k].z - pb;
                            let d3 = wc[4u + k].w - pa;
                            e2[k] = padd(
                                padd(
                                    padd(pmul(wr * d0, d0), pmul(wg * d1, d1)),
                                    pmul(wb * d2, d2),
                                ),
                                pmul(wa * d3, d3),
                            );
                        }
                        best_err = min(best_err, min(min(min(e2[0], e2[1]), e2[2]), e2[3]));
                        if (best_err == e2[0]) {
                            best_sel = 4;
                        }
                        if (best_err == e2[1]) {
                            best_sel = 5;
                        }
                        if (best_err == e2[2]) {
                            best_sel = 6;
                        }
                        if (best_err == e2[3]) {
                            best_sel = 7;
                        }
                    }
                    total_errf = padd(total_errf, best_err);
                    (*res).selectors_temp[i] = best_sel;
                }
            }
        }
    } else {
        let wgp = pval(wg * pr_weight());
        let wbp = pval(wb * pb_weight());
        var wy: array<f32, 16>;
        var wcr: array<f32, 16>;
        var wcb: array<f32, 16>;
        for (var i = 0u; i < 16u; i = i + 1u) {
            let r = wc[i].x;
            let g = wc[i].y;
            let b = wc[i].z;
            let y = luma3f(r, g, b);
            wy[i] = y;
            wcr[i] = psub(r, y);
            wcb[i] = psub(b, y);
        }
        if (p.has_alpha) {
            for (var i = 0u; i < num_pixels; i = i + 1u) {
                let r = f32((*pixels)[i].x);
                let g = f32((*pixels)[i].y);
                let b = f32((*pixels)[i].z);
                let a = f32((*pixels)[i].w);
                let y = luma3f(r, g, b);
                let cr = psub(r, y);
                let cb = psub(b, y);
                var best_err = 1e10;
                var best_sel = 0;
                for (var j = 0u; j < n; j = j + 1u) {
                    let dl = psub(y, wy[j]);
                    let dcr = psub(cr, wcr[j]);
                    let dcb = psub(cb, wcb[j]);
                    let da = psub(a, wc[j].w);
                    let err = padd(
                        padd(
                            padd(pmul(pval(wr * dl), dl), pmul(pval(wgp * dcr), dcr)),
                            pmul(pval(wbp * dcb), dcb),
                        ),
                        pmul(wa * da, da),
                    );
                    if (err < best_err) {
                        best_err = err;
                        best_sel = i32(j);
                    }
                }
                total_errf = padd(total_errf, best_err);
                (*res).selectors_temp[i] = best_sel;
            }
        } else {
            for (var i = 0u; i < num_pixels; i = i + 1u) {
                let r = f32((*pixels)[i].x);
                let g = f32((*pixels)[i].y);
                let b = f32((*pixels)[i].z);
                let y = luma3f(r, g, b);
                let cr = psub(r, y);
                let cb = psub(b, y);
                var best_err = 1e10;
                var best_sel = 0;
                for (var j = 0u; j < n; j = j + 1u) {
                    let dl = psub(y, wy[j]);
                    let dcr = psub(cr, wcr[j]);
                    let dcb = psub(cb, wcb[j]);
                    let err = padd(
                        padd(pmul(pval(wr * dl), dl), pmul(pval(wgp * dcr), dcr)),
                        pmul(pval(wbp * dcb), dcb),
                    );
                    if (err < best_err) {
                        best_err = err;
                        best_sel = i32(j);
                    }
                }
                total_errf = padd(total_errf, best_err);
                (*res).selectors_temp[i] = best_sel;
            }
        }
    }
    let total_err = f32_to_u64(total_errf);
    if (lt64(total_err, (*res).best_overall_err)) {
        (*res).best_overall_err = total_err;
        (*res).low = low;
        (*res).high = high;
        (*res).pbits = pbits;
        for (var i = 0u; i < num_pixels; i = i + 1u) {
            (*res).selectors[i] = (*res).selectors_temp[i];
        }
    }
    return total_err;
}

// Pack/eval test entries. blocks word streams:
// pack in-stride 75 (num_pixels r g b a nsw perceptual w[4] pixels[64]), out-stride 28
// (low[4] high[4] pbits[2] selectors[16] err.lo err.hi);
// fixdeg in-stride 18 (mode iscale tmin[4] tmax[4] xl[4] xh[4]), out-stride 8;
// evalsol in-stride 88 (nsw tbl comp_bits has_alpha has_pbits share perceptual num_pixels
// init_err[2] w[4] low[4] high[4] pbits[2] pixels[64]), out-stride 46 (ret[2] best[2]
// low[4] high[4] pbits[2] selectors[16] selectors_temp[16]).
const PACK_IN_STRIDE: u32 = 75u;
const PACK_OUT_STRIDE: u32 = 28u;

fn pack_test_common(gid: u32, mode: u32) {
    let ib = gid * PACK_IN_STRIDE;
    let num_pixels = blocks[ib];
    let r = blocks[ib + 1u];
    let g = blocks[ib + 2u];
    let b = blocks[ib + 3u];
    let a = blocks[ib + 4u];
    var p = ccparams_clear();
    p.num_selector_weights = blocks[ib + 5u];
    p.perceptual = blocks[ib + 6u] != 0u;
    p.weights = vec4<u32>(blocks[ib + 7u], blocks[ib + 8u], blocks[ib + 9u], blocks[ib + 10u]);
    var px: array<vec4<i32>, 16>;
    for (var i = 0u; i < 16u; i = i + 1u) {
        px[i] = in_vec4i(ib + 11u + i * 4u);
    }
    var res = ccresults_new();
    var e = vec2<u32>(0u, 0u);
    if (mode == 0u) {
        e = pack_mode0_to_one_color(p, &res, r, g, b, num_pixels, &px);
    } else if (mode == 1u) {
        e = pack_mode1_to_one_color(p, &res, r, g, b, num_pixels, &px);
    } else if (mode == 24u) {
        e = pack_mode24_to_one_color(p, &res, r, g, b, num_pixels, &px);
    } else if (mode == 6u) {
        e = pack_mode6_to_one_color(p, &res, r, g, b, a, num_pixels, &px);
    } else {
        e = pack_mode7_to_one_color(p, &res, r, g, b, a, num_pixels, &px);
    }
    let ob = gid * PACK_OUT_STRIDE;
    for (var i = 0u; i < 4u; i = i + 1u) {
        out_words[ob + i] = bitcast<u32>(res.low[i]);
        out_words[ob + 4u + i] = bitcast<u32>(res.high[i]);
    }
    out_words[ob + 8u] = res.pbits.x;
    out_words[ob + 9u] = res.pbits.y;
    for (var i = 0u; i < 16u; i = i + 1u) {
        out_words[ob + 10u + i] = bitcast<u32>(res.selectors[i]);
    }
    out_words[ob + 26u] = e.x;
    out_words[ob + 27u] = e.y;
}

@compute @workgroup_size(256)
fn bc7_test_pack_mode0(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    pack_test_common(gid, 0u);
}

