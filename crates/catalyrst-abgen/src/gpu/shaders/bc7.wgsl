}

const LSQ_IN_STRIDE: u32 = 84u;

fn lsq_load(
    ib: u32,
    sel: ptr<function, array<i32, 16>>,
    colors: ptr<function, array<vec4<i32>, 16>>,
) {
    for (var i = 0u; i < 16u; i = i + 1u) {
        (*sel)[i] = i32(blocks[ib + 4u + i]);
    }
    for (var i = 0u; i < 16u; i = i + 1u) {
        (*colors)[i] = in_vec4i(ib + 20u + i * 4u);
    }
}

