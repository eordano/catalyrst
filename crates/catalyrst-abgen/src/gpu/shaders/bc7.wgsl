// One-color packers + evaluate_solution. CCResults is function-local only; err is a u64
// pair (lo, hi). EndpointErr lookups use the S1 word convention (error=w&0xffff,
// lo=(w>>16)&0xff, hi=w>>24); mode5/mode4_3/mode4_2 words are raw lo|hi<<8.
// Interpolation (a*(64-w) + b*w + 32) * (1/64) then floor: the 1/64 reciprocal-mul is a
// power of two hence correctly rounded; every product feeding an add goes through pmul.
// Selector projection guards raw!=raw to mirror Rust's NaN-as-i32 == 0 saturating cast
// (reachable when amin==amax makes f infinite and the dot term exactly zero).

struct CCResults {
    best_overall_err: vec2<u32>,
    low: vec4<i32>,
    high: vec4<i32>,
    pbits: vec2<u32>,
    selectors: array<i32, 16>,
    selectors_temp: array<i32, 16>,
}

fn ccresults_new() -> CCResults {
    var r: CCResults;
    r.best_overall_err = vec2<u32>(0xffffffffu, 0xffffffffu);
    return r;
}

fn ep_error(w: u32) -> u32 {
    return w & 0xffffu;
}

fn ep_lo(w: u32) -> i32 {
    return i32((w >> 16u) & 0xffu);
}

fn ep_hi(w: u32) -> i32 {
    return i32(w >> 24u);
}

fn luma3f(r: f32, g: f32, b: f32) -> f32 {
    return padd(
        padd(
            pmul(r, bitcast<f32>(YR_BITS)),
            pmul(g, bitcast<f32>(YG_BITS)),
        ),
        pmul(b, bitcast<f32>(YB_BITS)),
    );
}

fn pack_mode1_to_one_color(
    p: CCParams,
    res: ptr<function, CCResults>,
    r: u32,
    g: u32,
    b: u32,
    num_pixels: u32,
    pixels: ptr<function, array<vec4<i32>, 16>>,
) -> vec2<u32> {
    var best_err = 0xffffffffu;
    var best_p = 0u;
    for (var pp = 0u; pp < 2u; pp = pp + 1u) {
        let err = ep_error(opt_tables[OPT_MODE1_OFF + r * 2u + pp])
            + ep_error(opt_tables[OPT_MODE1_OFF + g * 2u + pp])
            + ep_error(opt_tables[OPT_MODE1_OFF + b * 2u + pp]);
        if (err < best_err) {
            best_err = err;
            best_p = pp;
        }
    }
    let er = opt_tables[OPT_MODE1_OFF + r * 2u + best_p];
    let eg = opt_tables[OPT_MODE1_OFF + g * 2u + best_p];
    let eb = opt_tables[OPT_MODE1_OFF + b * 2u + best_p];
    (*res).low = vec4<i32>(ep_lo(er), ep_lo(eg), ep_lo(eb), 0);
    (*res).high = vec4<i32>(ep_hi(er), ep_hi(eg), ep_hi(eb), 0);
    (*res).pbits = vec2<u32>(best_p, 0u);
    for (var i = 0u; i < num_pixels; i = i + 1u) {
        (*res).selectors[i] = i32(MODE1_IDX);
    }
    var pc = vec4<i32>(0, 0, 0, 255);
    for (var i = 0u; i < 3u; i = i + 1u) {
        var lo = ((bitcast<u32>((*res).low[i]) << 1u) | best_p) << 1u;
        lo = lo | (lo >> 7u);
        var hi = ((bitcast<u32>((*res).high[i]) << 1u) | best_p) << 1u;
        hi = hi | (hi >> 7u);
        pc[i] = i32((lo * (64u - G_WEIGHTS3[MODE1_IDX]) + hi * G_WEIGHTS3[MODE1_IDX] + 32u) >> 6u);
    }
    var total = vec2<u32>(0u, 0u);
    for (var i = 0u; i < num_pixels; i = i + 1u) {
        total = add64(total, compute_color_distance_rgb(pc, (*pixels)[i], p.perceptual, p.weights));
    }
    (*res).best_overall_err = total;
    return total;
}

fn pack_mode24_to_one_color(
    p: CCParams,
    res: ptr<function, CCResults>,
    r: u32,
    g: u32,
    b: u32,
    num_pixels: u32,
    pixels: ptr<function, array<vec4<i32>, 16>>,
) -> vec2<u32> {
    var er: u32;
    var eg: u32;
    var eb: u32;
    if (p.num_selector_weights == 8u) {
        er = opt_tables[OPT_MODE4_3_OFF + r];
        eg = opt_tables[OPT_MODE4_3_OFF + g];
        eb = opt_tables[OPT_MODE4_3_OFF + b];
    } else {
        er = opt_tables[OPT_MODE4_2_OFF + r];
        eg = opt_tables[OPT_MODE4_2_OFF + g];
        eb = opt_tables[OPT_MODE4_2_OFF + b];
    }
    (*res).low = vec4<i32>(i32(er & 0xffu), i32(eg & 0xffu), i32(eb & 0xffu), 0);
    (*res).high = vec4<i32>(i32(er >> 8u), i32(eg >> 8u), i32(eb >> 8u), 0);
    var idx = MODE4_IDX2;
    if (p.num_selector_weights == 8u) {
        idx = MODE4_IDX3;
    }
    for (var i = 0u; i < num_pixels; i = i + 1u) {
        (*res).selectors[i] = i32(idx);
    }
    var pc = vec4<i32>(0, 0, 0, 255);
    for (var i = 0u; i < 3u; i = i + 1u) {
        var lo = bitcast<u32>((*res).low[i]) << 3u;
        lo = lo | (lo >> 5u);
        var hi = bitcast<u32>((*res).high[i]) << 3u;
        hi = hi | (hi >> 5u);
        if (p.num_selector_weights == 8u) {
            pc[i] = i32((lo * (64u - G_WEIGHTS3[MODE4_IDX3]) + hi * G_WEIGHTS3[MODE4_IDX3] + 32u) >> 6u);
        } else {
            pc[i] = i32((lo * (64u - G_WEIGHTS2[MODE4_IDX2]) + hi * G_WEIGHTS2[MODE4_IDX2] + 32u) >> 6u);
        }
    }
    var total = vec2<u32>(0u, 0u);
    for (var i = 0u; i < num_pixels; i = i + 1u) {
        total = add64(total, compute_color_distance_rgb(pc, (*pixels)[i], p.perceptual, p.weights));
    }
    (*res).best_overall_err = total;
    return total;
}

