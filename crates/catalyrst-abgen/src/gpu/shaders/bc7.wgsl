const FIXDEG_IN_STRIDE: u32 = 18u;

@compute @workgroup_size(256)
fn bc7_test_fixdeg(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * FIXDEG_IN_STRIDE;
    let mode = blocks[ib];
    let iscale = i32(blocks[ib + 1u]);
    var tmin = in_vec4i(ib + 2u);
    var tmax = in_vec4i(ib + 6u);
    let xl = in_vec4f(ib + 10u);
    let xh = in_vec4f(ib + 14u);
    fix_degenerate_endpoints(mode, &tmin, &tmax, xl, xh, iscale);
    let ob = gid * 8u;
    for (var i = 0u; i < 4u; i = i + 1u) {
        out_words[ob + i] = bitcast<u32>(tmin[i]);
        out_words[ob + 4u + i] = bitcast<u32>(tmax[i]);
    }
}

const EVALSOL_IN_STRIDE: u32 = 88u;
const EVALSOL_OUT_STRIDE: u32 = 46u;

@compute @workgroup_size(256)
fn bc7_test_evalsol(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * EVALSOL_IN_STRIDE;
    var p = ccparams_clear();
    p.num_selector_weights = blocks[ib];
    p.sel_table = blocks[ib + 1u];
    p.comp_bits = blocks[ib + 2u];
    p.has_alpha = blocks[ib + 3u] != 0u;
    p.has_pbits = blocks[ib + 4u] != 0u;
    p.endpoints_share_pbit = blocks[ib + 5u] != 0u;
    p.perceptual = blocks[ib + 6u] != 0u;
    let num_pixels = blocks[ib + 7u];
    let init_err = vec2<u32>(blocks[ib + 8u], blocks[ib + 9u]);
    p.weights = vec4<u32>(blocks[ib + 10u], blocks[ib + 11u], blocks[ib + 12u], blocks[ib + 13u]);
    let low = in_vec4i(ib + 14u);
    let high = in_vec4i(ib + 18u);
    let pb = vec2<u32>(blocks[ib + 22u], blocks[ib + 23u]);
    var px: array<vec4<i32>, 16>;
    for (var i = 0u; i < 16u; i = i + 1u) {
        px[i] = in_vec4i(ib + 24u + i * 4u);
    }
    var res = ccresults_new();
    res.best_overall_err = init_err;
    let e = evaluate_solution(low, high, pb, p, &res, num_pixels, &px);
    let ob = gid * EVALSOL_OUT_STRIDE;
    out_words[ob] = e.x;
    out_words[ob + 1u] = e.y;
    out_words[ob + 2u] = res.best_overall_err.x;
    out_words[ob + 3u] = res.best_overall_err.y;
    for (var i = 0u; i < 4u; i = i + 1u) {
        out_words[ob + 4u + i] = bitcast<u32>(res.low[i]);
        out_words[ob + 8u + i] = bitcast<u32>(res.high[i]);
    }
    out_words[ob + 12u] = res.pbits.x;
    out_words[ob + 13u] = res.pbits.y;
    for (var i = 0u; i < 16u; i = i + 1u) {
        out_words[ob + 14u + i] = bitcast<u32>(res.selectors[i]);
        out_words[ob + 30u + i] = bitcast<u32>(res.selectors_temp[i]);
    }
}

// color_cell_compression core. Contract vs bc7.rs:
// - run_ls closure -> fn ccc_run_ls(sel ptr + explicit pbit flag); the refinement-pass loop
//   copies res.selectors[0..n] into a temp array and calls the same fn (identical evaluation
//   order: lsq -> *1/255 -> find_optimal_solution). uber2 passes pbit_search && uber_level>=2.
// - eval_4way tiebreak: the Rust rank tuple (pbits[0],pbits[1]) equals the option index k,
//   so an ascending scan taking the LAST option within band mirrors the strict rank> compare.
// - div_exact: correctly-rounded a/b (byte-chunk long division on 24-bit mantissas, RNE) for
//   the two true-division sites (shared-pbit endpoint error /255, uber2 selector remap);
//   +-0 numerator short-circuits to signed zero, non-normal input/exponent falls back to
//   hardware (unreachable in-band). All Rust 1.0/x sites stay recip_exact.
// - non-exact float literals travel as pinned bit consts (host test ccc_const_bits_pin):
//   1/255, PCA seeds 0.9/0.7, 1e-10 eps, perceptual axis fallback 0.213/0.715/0.072.
// Test streams: eval4way in-stride 104 out 44; findopt in-stride 98 out 46 (ret[2] + ccres);
// ccc in-stride 82 out 44; div in-stride 2 out 1. ccres out = err[2] low[4] high[4] pbits[2]
// selectors[16] selectors_temp[16].

const U64_MAX = vec2<u32>(0xffffffffu, 0xffffffffu);
const U64_ZERO = vec2<u32>(0u, 0u);
const CCC_INV255_BITS: u32 = 0x3b808081u;
const AXIS_R_BITS: u32 = 0x3e5a1cacu;
const AXIS_G_BITS: u32 = 0x3f370a3du;
const AXIS_B_BITS: u32 = 0x3d9374bcu;
const PCA_SEED_R_BITS: u32 = 0x3f666666u;
const PCA_SEED_B_BITS: u32 = 0x3f333333u;
const CCC_EPS_BITS: u32 = 0x2edbe6ffu;

fn psub4(a: vec4<f32>, b: vec4<f32>) -> vec4<f32> {
    return (a - b) * fone();
}

fn div_exact(a: f32, b: f32) -> f32 {
    let ba = bitcast<u32>(a);
    let bb = bitcast<u32>(b);
    if ((ba & 0x7fffffffu) == 0u) {
        return bitcast<f32>((ba ^ bb) & 0x80000000u);
    }
    let ea = (ba >> 23u) & 0xffu;
    let eb = (bb >> 23u) & 0xffu;
    if (ea == 0u || ea == 255u || eb == 0u || eb == 255u) {
        return a / b;
    }
    let sign = (ba ^ bb) & 0x80000000u;
    let ma = (ba & 0x7fffffu) | 0x800000u;
    let mb = (bb & 0x7fffffu) | 0x800000u;
    var s = 24u;
    var e = i32(ea) - i32(eb) + 126;
    if (ma >= mb) {
        s = 23u;
        e = e + 1;
    }
    let n = vec2<u32>(ma << s, ma >> (32u - s));
    var rem = 0u;
    var q = 0u;
    for (var i = 0u; i < 8u; i = i + 1u) {
        var byte_v = 0u;
        if (i < 4u) {
            byte_v = (n.y >> ((3u - i) * 8u)) & 0xffu;
        } else {
            byte_v = (n.x >> ((7u - i) * 8u)) & 0xffu;
        }
        let acc = (rem << 8u) | byte_v;
        q = (q << 8u) | (acc / mb);
        rem = acc % mb;
    }
    let r2 = rem << 1u;
    if (r2 > mb || (r2 == mb && (q & 1u) == 1u)) {
        q = q + 1u;
        if (q == 0x1000000u) {
            q = 0x800000u;
            e = e + 1;
        }
    }
    if (e <= 0 || e >= 255) {
        return a / b;
    }
    return bitcast<f32>(sign | (u32(e) << 23u) | (q & 0x7fffffu));
}

fn eval_4way_pbit_with_tiebreak(
    lo: ptr<function, array<vec4<i32>, 2>>,
    hi: ptr<function, array<vec4<i32>, 2>>,
    p: CCParams,
    res: ptr<function, CCResults>,
    num_pixels: u32,
    pixels: ptr<function, array<vec4<i32>, 16>>,
) {
    var errs: array<vec2<u32>, 4>;
    var snaps: array<CCResults, 4>;
    let baseline = *res;
    for (var k = 0u; k < 4u; k = k + 1u) {
        var local = baseline;
        let e = evaluate_solution(
            (*lo)[k >> 1u],
            (*hi)[k & 1u],
            vec2<u32>(k >> 1u, k & 1u),
            p,
            &local,
            num_pixels,
            pixels,
        );
        errs[k] = e;
        snaps[k] = local;
    }
    var min_err = errs[0];
    for (var k = 1u; k < 4u; k = k + 1u) {
        if (lt64(errs[k], min_err)) {
            min_err = errs[k];
        }
    }
    let band = saturating_add64(min_err, shr64(min_err, 13u));
    var winner = 0u;
    for (var k = 0u; k < 4u; k = k + 1u) {
        if (le64(errs[k], band)) {
            winner = k;
        }
    }
    if (lt64(snaps[winner].best_overall_err, (*res).best_overall_err)) {
        *res = snaps[winner];
    }
}

fn quant_pbit(x: f32, scalep: f32, iscalep: i32, p_i: i32) -> i32 {
    let q = itrunc(psub(pmul(x, scalep), f32(p_i)) * 0.5 + 0.5) * 2 + p_i;
    return clamp(q, p_i, iscalep - 1 + p_i);
}

fn find_optimal_solution(
    mode: u32,
    pxl: vec4<f32>,
    pxh: vec4<f32>,
    p: CCParams,
    res: ptr<function, CCResults>,
    pbit_search: bool,
    num_pixels: u32,
    pixels: ptr<function, array<vec4<i32>, 16>>,
) -> vec2<u32> {
    let xl = clamp(pxl, vec4<f32>(0.0), vec4<f32>(1.0));
    let xh = clamp(pxh, vec4<f32>(0.0), vec4<f32>(1.0));
    var cl: array<vec4<i32>, 4>;
    var ch: array<vec4<i32>, 4>;
    var cpb: array<vec2<u32>, 4>;
    var ncand = 0u;
    var use_4way = false;
    var lo4: array<vec4<i32>, 2>;
    var hi4: array<vec4<i32>, 2>;
    if (p.has_pbits) {
        let iscalep = (i32(1) << (p.comp_bits + 1u)) - 1;
        let scalep = f32(iscalep);
        var total_comps = 3u;
        if (p.has_alpha) {
            total_comps = 4u;
        }
        if (pbit_search) {
            for (var pp = 0; pp < 2; pp = pp + 1) {
                var xmin = vec4<i32>(0);
                var xmax = vec4<i32>(0);
                for (var c = 0u; c < 4u; c = c + 1u) {
                    xmin[c] = quant_pbit(xl[c], scalep, iscalep, pp);
                    xmax[c] = quant_pbit(xh[c], scalep, iscalep, pp);
                }
                lo4[pp] = xmin >> vec4<u32>(1u);
                hi4[pp] = xmax >> vec4<u32>(1u);
            }
            var t0 = lo4[0];
            var t1 = hi4[0];
            fix_degenerate_endpoints(mode, &t0, &t1, xl, xh, iscalep >> 1u);
            lo4[0] = t0;
            hi4[0] = t1;
            t0 = lo4[1];
            t1 = hi4[1];
            fix_degenerate_endpoints(mode, &t0, &t1, xl, xh, iscalep >> 1u);
            lo4[1] = t0;
            hi4[1] = t1;
            if (!p.endpoints_share_pbit) {
                if (mode == 6u) {
                    use_4way = true;
                } else {
                    for (var k = 0u; k < 4u; k = k + 1u) {
                        cl[k] = lo4[k >> 1u];
                        ch[k] = hi4[k & 1u];
                        cpb[k] = vec2<u32>(k >> 1u, k & 1u);
                    }
                    ncand = 4u;
                }
            } else {
                cl[0] = lo4[0];
                ch[0] = hi4[0];
                cpb[0] = vec2<u32>(0u, 0u);
                cl[1] = lo4[1];
                ch[1] = hi4[1];
                cpb[1] = vec2<u32>(1u, 1u);
                ncand = 2u;
            }
        } else {
            var best_pbits = vec2<u32>(0u, 0u);
            var best_min = vec4<i32>(0);
            var best_max = vec4<i32>(0);
            if (!p.endpoints_share_pbit) {
                var best_err0 = 1e9;
                var best_err1 = 1e9;
                for (var pp = 0; pp < 2; pp = pp + 1) {
                    var xmin = vec4<i32>(0);
                    var xmax = vec4<i32>(0);
                    for (var c = 0u; c < 4u; c = c + 1u) {
                        xmin[c] = quant_pbit(xl[c], scalep, iscalep, pp);
                        xmax[c] = quant_pbit(xh[c], scalep, iscalep, pp);
                    }
                    let sl = scale_color(xmin, p);
                    let sh = scale_color(xmax, p);
                    var err0 = 0.0;
                    var err1 = 0.0;
                    for (var i = 0u; i < total_comps; i = i + 1u) {
                        let d0 = psub(f32(sl[i]), pmul(xl[i], 255.0));
                        let d1 = psub(f32(sh[i]), pmul(xh[i], 255.0));
                        err0 = padd(err0, pmul(d0, d0));
                        err1 = padd(err1, pmul(d1, d1));
                    }
                    if (err0 < best_err0) {
                        best_err0 = err0;
                        best_pbits.x = u32(pp);
                        best_min = xmin >> vec4<u32>(1u);
                    }
                    if (err1 < best_err1) {
                        best_err1 = err1;
                        best_pbits.y = u32(pp);
                        best_max = xmax >> vec4<u32>(1u);
                    }
                }
            } else {
                var best_err = 1e9;
                for (var pp = 0; pp < 2; pp = pp + 1) {
                    var xmin = vec4<i32>(0);
                    var xmax = vec4<i32>(0);
                    for (var c = 0u; c < 4u; c = c + 1u) {
                        xmin[c] = quant_pbit(xl[c], scalep, iscalep, pp);
                        xmax[c] = quant_pbit(xh[c], scalep, iscalep, pp);
                    }
                    let sl = scale_color(xmin, p);
                    let sh = scale_color(xmax, p);
                    var err = 0.0;
                    for (var i = 0u; i < total_comps; i = i + 1u) {
                        let d0 = psub(div_exact(f32(sl[i]), 255.0), xl[i]);
                        let d1 = psub(div_exact(f32(sh[i]), 255.0), xh[i]);
                        err = padd(err, padd(pmul(d0, d0), pmul(d1, d1)));
                    }
                    if (err < best_err) {
                        best_err = err;
                        best_pbits = vec2<u32>(u32(pp), u32(pp));
                        best_min = xmin >> vec4<u32>(1u);
                        best_max = xmax >> vec4<u32>(1u);
                    }
                }
            }
            var tmin = best_min;
            var tmax = best_max;
            fix_degenerate_endpoints(mode, &tmin, &tmax, xl, xh, iscalep >> 1u);
            best_min = tmin;
            best_max = tmax;
            if (eq64((*res).best_overall_err, U64_MAX)
                || any(best_min != (*res).low)
                || any(best_max != (*res).high)
                || best_pbits.x != (*res).pbits.x
                || best_pbits.y != (*res).pbits.y) {
                cl[0] = best_min;
                ch[0] = best_max;
                cpb[0] = best_pbits;
                ncand = 1u;
            }
        }
    } else {
        let iscale = (i32(1) << p.comp_bits) - 1;
        let scale = f32(iscale);
        var tmin = vec4<i32>(0);
        var tmax = vec4<i32>(0);
        for (var c = 0u; c < 4u; c = c + 1u) {
            tmin[c] = clamp(itrunc(pmul(xl[c], scale) + 0.5), 0, 255);
            tmax[c] = clamp(itrunc(pmul(xh[c], scale) + 0.5), 0, 255);
        }
        fix_degenerate_endpoints(mode, &tmin, &tmax, xl, xh, iscale);
        if (eq64((*res).best_overall_err, U64_MAX)
            || any(tmin != (*res).low)
            || any(tmax != (*res).high)) {
            cl[ncand] = tmin;
            ch[ncand] = tmax;
            cpb[ncand] = vec2<u32>(0u, 0u);
            ncand = ncand + 1u;
        }
        if (mode == 2u) {
            var smin = tmin;
            var smax = tmax;
            for (var c = 0u; c < 3u; c = c + 1u) {
                if (smin[c] < iscale) {
                    smin[c] = smin[c] + 1;
                }
                if (smax[c] > 0) {
                    smax[c] = smax[c] - 1;
                }
            }
            if (any(smin != tmin) || any(smax != tmax)) {
                cl[ncand] = smin;
                ch[ncand] = smax;
                cpb[ncand] = vec2<u32>(0u, 0u);
                ncand = ncand + 1u;
            }
        }
    }
    if (use_4way) {
        eval_4way_pbit_with_tiebreak(&lo4, &hi4, p, res, num_pixels, pixels);
    }
    for (var k = 0u; k < ncand; k = k + 1u) {
        _ = evaluate_solution(cl[k], ch[k], cpb[k], p, res, num_pixels, pixels);
    }
    return (*res).best_overall_err;
}

fn ccc_run_ls(
    mode: u32,
    sel: ptr<function, array<i32, 16>>,
    p: CCParams,
    pbit_flag: bool,
    res: ptr<function, CCResults>,
    num_pixels: u32,
    pixels: ptr<function, array<vec4<i32>, 16>>,
) -> vec2<u32> {
    var xl = vec4<f32>(0.0);
    var xh = vec4<f32>(0.0);
    if (p.has_alpha) {
        compute_lsq_endpoints_rgba(num_pixels, sel, p.sel_table, &xl, &xh, pixels);
    } else {
        compute_lsq_endpoints_rgb(num_pixels, sel, p.sel_table, &xl, &xh, pixels);
        xl.w = 255.0;
        xh.w = 255.0;
    }
    let inv255 = bitcast<f32>(CCC_INV255_BITS);
    xl = pmul4(inv255, xl);
    xh = pmul4(inv255, xh);
    return find_optimal_solution(mode, xl, xh, p, res, pbit_flag, num_pixels, pixels);
}

fn ccc_pack_one_color(
    mode: u32,
    p: CCParams,
    res: ptr<function, CCResults>,
    r: u32,
    g: u32,
    b: u32,
    a: u32,
    num_pixels: u32,
    pixels: ptr<function, array<vec4<i32>, 16>>,
) -> vec2<u32> {
    if (mode == 0u) {
        return pack_mode0_to_one_color(p, res, r, g, b, num_pixels, pixels);
    }
    if (mode == 1u) {
        return pack_mode1_to_one_color(p, res, r, g, b, num_pixels, pixels);
    }
    if (mode == 6u) {
        return pack_mode6_to_one_color(p, res, r, g, b, a, num_pixels, pixels);
    }
    if (mode == 7u) {
        return pack_mode7_to_one_color(p, res, r, g, b, a, num_pixels, pixels);
    }
    return pack_mode24_to_one_color(p, res, r, g, b, num_pixels, pixels);
}

fn color_cell_compression(
    mode: u32,
    p: CCParams,
    res: ptr<function, CCResults>,
    pbit_search: bool,
    refinement_passes: u32,
    uber_level: u32,
    uber1_mask: u32,
    num_pixels: u32,
    pixels: ptr<function, array<vec4<i32>, 16>>,
    refinement: bool,
) -> vec2<u32> {
    (*res).best_overall_err = U64_MAX;
    let onecolor_modes = (mode <= 2u) || (mode == 4u) || (mode >= 6u);
    if (onecolor_modes) {
        let c0 = (*pixels)[0];
        var all_same = true;
        for (var i = 1u; i < num_pixels; i = i + 1u) {
            if (any((*pixels)[i] != c0)) {
                all_same = false;
                break;
            }
        }
        if (all_same) {
            return ccc_pack_one_color(
                mode, p, res,
                u32(c0.x), u32(c0.y), u32(c0.z), u32(c0.w),
                num_pixels, pixels,
            );
        }
    }
    var mean4 = vec4<f32>(0.0);
    for (var i = 0u; i < num_pixels; i = i + 1u) {
        mean4 = mean4 + vec4<f32>((*pixels)[i]);
    }
    let inv_n = recip_exact(f32(num_pixels));
    let mean_scaled = pmul4(inv_n, mean4);
    let inv_n255 = recip_exact(f32(num_pixels) * 255.0);
    let mean = clamp(pmul4(inv_n255, mean4), vec4<f32>(0.0), vec4<f32>(1.0));
    var axis = vec4<f32>(0.0);
    if (p.has_alpha) {
        var v = vec4<f32>(0.0);
        for (var i = 0u; i < num_pixels; i = i + 1u) {
            let color = psub4(vec4<f32>((*pixels)[i]), mean_scaled);
            let ca = vec4<f32>(
                pmul(color.x, color.x),
                pmul(color.y, color.x),
                pmul(color.z, color.x),
                pmul(color.w, color.x),
            );
            let cb = vec4<f32>(
                pmul(color.x, color.y),
                pmul(color.y, color.y),
                pmul(color.z, color.y),
                pmul(color.w, color.y),
            );
            let cc = vec4<f32>(
                pmul(color.x, color.z),
                pmul(color.y, color.z),
                pmul(color.z, color.z),
                pmul(color.w, color.z),
            );
            let cd = vec4<f32>(
                pmul(color.x, color.w),
                pmul(color.y, color.w),
                pmul(color.z, color.w),
                pmul(color.w, color.w),
            );
            var nrm = color;
            if (i != 0u) {
                nrm = v;
            }
            nrm = vec4f_normalize(nrm);
            v = vec4<f32>(
                padd(v.x, vec4f_dot(ca, nrm)),
                padd(v.y, vec4f_dot(cb, nrm)),
                padd(v.z, vec4f_dot(cc, nrm)),
                padd(v.w, vec4f_dot(cd, nrm)),
            );
        }
        axis = vec4f_normalize(v);
    } else {
        var cov: array<f32, 6>;
        for (var i = 0u; i < num_pixels; i = i + 1u) {
            let r = psub(f32((*pixels)[i].x), mean_scaled.x);
            let g = psub(f32((*pixels)[i].y), mean_scaled.y);
            let b = psub(f32((*pixels)[i].z), mean_scaled.z);
            cov[0] = padd(cov[0], pmul(r, r));
            cov[1] = padd(cov[1], pmul(r, g));
            cov[2] = padd(cov[2], pmul(r, b));
            cov[3] = padd(cov[3], pmul(g, g));
            cov[4] = padd(cov[4], pmul(g, b));
            cov[5] = padd(cov[5], pmul(b, b));
        }
        var vfr = bitcast<f32>(PCA_SEED_R_BITS);
        var vfg = 1.0;
        var vfb = bitcast<f32>(PCA_SEED_B_BITS);
        for (var it = 0u; it < 3u; it = it + 1u) {
            let r = padd(padd(pmul(vfr, cov[0]), pmul(vfg, cov[1])), pmul(vfb, cov[2]));
            let g = padd(padd(pmul(vfr, cov[1]), pmul(vfg, cov[3])), pmul(vfb, cov[4]));
            let b = padd(padd(pmul(vfr, cov[2]), pmul(vfg, cov[4])), pmul(vfb, cov[5]));
            var m = max(max(abs(r), abs(g)), abs(b));
            var rr = r;
            var gg = g;
            var bb = b;
            if (m > bitcast<f32>(CCC_EPS_BITS)) {
                m = recip_exact(m);
                rr = pmul(r, m);
                gg = pmul(g, m);
                bb = pmul(b, m);
            }
            vfr = rr;
            vfg = gg;
            vfb = bb;
        }
        let len2 = padd(padd(pmul(vfr, vfr), pmul(vfg, vfg)), pmul(vfb, vfb));
        if (len2 < bitcast<f32>(CCC_EPS_BITS)) {
            axis = vec4<f32>(0.0);
        } else {
            let inv = recip_exact(sqrt_exact(len2));
            axis = vec4<f32>(pmul(vfr, inv), pmul(vfg, inv), pmul(vfb, inv), 0.0);
        }
    }
    if (vec4f_dot(axis, axis) < 0.5) {
        if (p.perceptual) {
            var aw = 0.0;
            if (p.has_alpha) {
                aw = bitcast<f32>(AXIS_G_BITS);
            }
            axis = vec4<f32>(
                bitcast<f32>(AXIS_R_BITS),
                bitcast<f32>(AXIS_G_BITS),
                bitcast<f32>(AXIS_B_BITS),
                aw,
            );
        } else {
            var aw = 0.0;
            if (p.has_alpha) {
                aw = 1.0;
            }
            axis = vec4<f32>(1.0, 1.0, 1.0, aw);
        }
        axis = vec4f_normalize(axis);
    }
    var l = 1e9;
    var h = -1e9;
    for (var i = 0u; i < num_pixels; i = i + 1u) {
        let q = psub4(vec4<f32>((*pixels)[i]), mean_scaled);
        let d = vec4f_dot(q, axis);
        l = min(l, d);
        h = max(h, d);
    }
    let inv255 = bitcast<f32>(CCC_INV255_BITS);
    l = pmul(l, inv255);
    h = pmul(h, inv255);
    var min_color = vec4<f32>(0.0);
    var max_color = vec4<f32>(0.0);
    for (var c = 0u; c < 4u; c = c + 1u) {
        min_color[c] = fsaturate(mean[c] + pmul(axis[c], l));
        max_color[c] = fsaturate(mean[c] + pmul(axis[c], h));
    }
    let white = vec4<f32>(1.0);
    if (vec4f_dot(min_color, white) > vec4f_dot(max_color, white)) {
        let t = min_color;
        min_color = max_color;
        max_color = t;
    }
    if (eq64(
        find_optimal_solution(mode, min_color, max_color, p, res, pbit_search, num_pixels, pixels),
        U64_ZERO,
    )) {
        return U64_ZERO;
    }
    if (!refinement) {
        return (*res).best_overall_err;
    }
    for (var rp = 0u; rp < refinement_passes; rp = rp + 1u) {
        var seltmp: array<i32, 16>;
        for (var i = 0u; i < num_pixels; i = i + 1u) {
            seltmp[i] = (*res).selectors[i];
        }
        if (eq64(ccc_run_ls(mode, &seltmp, p, pbit_search, res, num_pixels, pixels), U64_ZERO)) {
            return U64_ZERO;
        }
    }
    if (uber_level > 0u) {
        var selectors_temp: array<i32, 16>;
        for (var i = 0u; i < num_pixels; i = i + 1u) {
            selectors_temp[i] = (*res).selectors[i];
        }
        let max_selector = i32(p.num_selector_weights) - 1;
        var min_sel = 16u;
        var max_sel = 0u;
        for (var i = 0u; i < num_pixels; i = i + 1u) {
            let s = u32(selectors_temp[i]);
            min_sel = min(min_sel, s);
            max_sel = max(max_sel, s);
        }
        var selectors_temp1: array<i32, 16>;
        for (var u1 = 0u; u1 < 3u; u1 = u1 + 1u) {
            if ((uber1_mask & (1u << u1)) == 0u) {
                continue;
            }
            for (var i = 0u; i < num_pixels; i = i + 1u) {
                var s = u32(selectors_temp[i]);
                if (u1 == 0u) {
                    if (s == min_sel && s < p.num_selector_weights - 1u) {
                        s = s + 1u;
                    }
                } else if (u1 == 1u) {
                    if (s == max_sel && s > 0u) {
                        s = s - 1u;
                    }
                } else {
                    if (s == min_sel && s < p.num_selector_weights - 1u) {
                        s = s + 1u;
                    } else if (s == max_sel && s > 0u) {
                        s = s - 1u;
                    }
                }
                selectors_temp1[i] = i32(s);
            }
            if (eq64(ccc_run_ls(mode, &selectors_temp1, p, pbit_search, res, num_pixels, pixels), U64_ZERO)) {
                return U64_ZERO;
            }
        }
        let uber_err_thresh = (num_pixels * 56u) >> 4u;
        if (uber_level >= 2u && lt64(vec2<u32>(uber_err_thresh, 0u), (*res).best_overall_err)) {
            var q = 1;
            if (uber_level >= 4u) {
                q = i32(uber_level) - 2;
            }
            for (var ly = -q; ly <= 1; ly = ly + 1) {
                for (var hy = max_selector - 1; hy <= max_selector + q; hy = hy + 1) {
                    if (!(ly == 0 && hy == max_selector)) {
                        for (var i = 0u; i < num_pixels; i = i + 1u) {
                            let t = f32(max_selector) * (f32(selectors_temp[i]) - f32(ly));
                            let rq = floor(div_exact(t, f32(hy) - f32(ly)) + 0.5);
                            selectors_temp1[i] = itrunc(clamp(rq, 0.0, f32(max_selector)));
                        }
                        let pb = pbit_search && (uber_level >= 2u);
                        if (eq64(ccc_run_ls(mode, &selectors_temp1, p, pb, res, num_pixels, pixels), U64_ZERO)) {
                            return U64_ZERO;
                        }
                    }
                }
            }
        }
    }
    if (onecolor_modes) {
        var avg = ccresults_new();
        avg.best_overall_err = (*res).best_overall_err;
        let r = u32(itrunc(0.5 + pmul(mean.x, 255.0)));
        let g = u32(itrunc(0.5 + pmul(mean.y, 255.0)));
        let b = u32(itrunc(0.5 + pmul(mean.z, 255.0)));
        let a = u32(itrunc(0.5 + pmul(mean.w, 255.0)));
        let avg_err = ccc_pack_one_color(mode, p, &avg, r, g, b, a, num_pixels, pixels);
        if (lt64(avg_err, (*res).best_overall_err)) {
            (*res).best_overall_err = avg_err;
            (*res).low = avg.low;
            (*res).high = avg.high;
            (*res).pbits = avg.pbits;
            for (var i = 0u; i < num_pixels; i = i + 1u) {
                (*res).selectors[i] = avg.selectors[i];
            }
        }
    }
    return (*res).best_overall_err;
}

fn write_ccres(ob: u32, res: ptr<function, CCResults>) {
    out_words[ob] = (*res).best_overall_err.x;
    out_words[ob + 1u] = (*res).best_overall_err.y;
    for (var i = 0u; i < 4u; i = i + 1u) {
        out_words[ob + 2u + i] = bitcast<u32>((*res).low[i]);
        out_words[ob + 6u + i] = bitcast<u32>((*res).high[i]);
    }
    out_words[ob + 10u] = (*res).pbits.x;
    out_words[ob + 11u] = (*res).pbits.y;
    for (var i = 0u; i < 16u; i = i + 1u) {
        out_words[ob + 12u + i] = bitcast<u32>((*res).selectors[i]);
        out_words[ob + 28u + i] = bitcast<u32>((*res).selectors_temp[i]);
    }
}

const E4W_IN_STRIDE: u32 = 104u;
const E4W_OUT_STRIDE: u32 = 44u;

@compute @workgroup_size(256)
fn bc7_test_eval4way(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * E4W_IN_STRIDE;
    var p = ccparams_clear();
    p.num_selector_weights = blocks[ib];
    p.sel_table = blocks[ib + 1u];
    p.comp_bits = blocks[ib + 2u];
    p.has_alpha = blocks[ib + 3u] != 0u;
    p.has_pbits = blocks[ib + 4u] != 0u;
    p.endpoints_share_pbit = blocks[ib + 5u] != 0u;
    p.perceptual = blocks[ib + 6u] != 0u;
    p.weights = vec4<u32>(blocks[ib + 7u], blocks[ib + 8u], blocks[ib + 9u], blocks[ib + 10u]);
    let num_pixels = blocks[ib + 11u];
    var res = ccresults_new();
    res.best_overall_err = vec2<u32>(blocks[ib + 12u], blocks[ib + 13u]);
    res.low = in_vec4i(ib + 14u);
    res.high = in_vec4i(ib + 18u);
    res.pbits = vec2<u32>(blocks[ib + 22u], blocks[ib + 23u]);
    var lo: array<vec4<i32>, 2>;
    var hi: array<vec4<i32>, 2>;
    lo[0] = in_vec4i(ib + 24u);
    lo[1] = in_vec4i(ib + 28u);
    hi[0] = in_vec4i(ib + 32u);
    hi[1] = in_vec4i(ib + 36u);
    var px: array<vec4<i32>, 16>;
    for (var i = 0u; i < 16u; i = i + 1u) {
        px[i] = in_vec4i(ib + 40u + i * 4u);
    }
    eval_4way_pbit_with_tiebreak(&lo, &hi, p, &res, num_pixels, &px);
    write_ccres(gid * E4W_OUT_STRIDE, &res);
}

const FINDOPT_IN_STRIDE: u32 = 98u;
const FINDOPT_OUT_STRIDE: u32 = 46u;

@compute @workgroup_size(256)
fn bc7_test_findopt(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * FINDOPT_IN_STRIDE;
    let mode = blocks[ib];
    var p = ccparams_clear();
    p.num_selector_weights = blocks[ib + 1u];
    p.sel_table = blocks[ib + 2u];
    p.comp_bits = blocks[ib + 3u];
    p.has_alpha = blocks[ib + 4u] != 0u;
    p.has_pbits = blocks[ib + 5u] != 0u;
    p.endpoints_share_pbit = blocks[ib + 6u] != 0u;
    p.perceptual = blocks[ib + 7u] != 0u;
    p.weights = vec4<u32>(blocks[ib + 8u], blocks[ib + 9u], blocks[ib + 10u], blocks[ib + 11u]);
    let pbit_search = blocks[ib + 12u] != 0u;
    let num_pixels = blocks[ib + 13u];
    var res = ccresults_new();
    res.best_overall_err = vec2<u32>(blocks[ib + 14u], blocks[ib + 15u]);
    res.low = in_vec4i(ib + 16u);
    res.high = in_vec4i(ib + 20u);
    res.pbits = vec2<u32>(blocks[ib + 24u], blocks[ib + 25u]);
    let xl = in_vec4f(ib + 26u);
    let xh = in_vec4f(ib + 30u);
    var px: array<vec4<i32>, 16>;
    for (var i = 0u; i < 16u; i = i + 1u) {
        px[i] = in_vec4i(ib + 34u + i * 4u);
    }
    let e = find_optimal_solution(mode, xl, xh, p, &res, pbit_search, num_pixels, &px);
    let ob = gid * FINDOPT_OUT_STRIDE;
    out_words[ob] = e.x;
    out_words[ob + 1u] = e.y;
    write_ccres(ob + 2u, &res);
}

const CCC_IN_STRIDE: u32 = 82u;
const CCC_OUT_STRIDE: u32 = 44u;

@compute @workgroup_size(256)
fn bc7_test_ccc(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * CCC_IN_STRIDE;
    let mode = blocks[ib];
    var p = ccparams_clear();
    p.num_selector_weights = blocks[ib + 1u];
    p.sel_table = blocks[ib + 2u];
    p.comp_bits = blocks[ib + 3u];
    p.has_alpha = blocks[ib + 4u] != 0u;
    p.has_pbits = blocks[ib + 5u] != 0u;
    p.endpoints_share_pbit = blocks[ib + 6u] != 0u;
    p.perceptual = blocks[ib + 7u] != 0u;
    p.weights = vec4<u32>(blocks[ib + 8u], blocks[ib + 9u], blocks[ib + 10u], blocks[ib + 11u]);
    let pbit_search = blocks[ib + 12u] != 0u;
    let refinement_passes = blocks[ib + 13u];
    let uber_level = blocks[ib + 14u];
    let uber1_mask = blocks[ib + 15u];
    let refinement = blocks[ib + 16u] != 0u;
    let num_pixels = blocks[ib + 17u];
    var px: array<vec4<i32>, 16>;
    for (var i = 0u; i < 16u; i = i + 1u) {
        px[i] = in_vec4i(ib + 18u + i * 4u);
    }
    var res = ccresults_new();
    _ = color_cell_compression(
        mode, p, &res,
        pbit_search, refinement_passes, uber_level, uber1_mask,
        num_pixels, &px, refinement,
    );
    write_ccres(gid * CCC_OUT_STRIDE, &res);
}

@compute @workgroup_size(256)
fn bc7_test_div(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let a = bitcast<f32>(blocks[gid * 2u]);
    let b = bitcast<f32>(blocks[gid * 2u + 1u]);
    out_words[gid] = bitcast<u32>(div_exact(a, b));
}

// Estimation + partition planning + mode-tree hint. Contract vs bc7.rs / mode_tree.rs:
// - ccc_est_idx / ccc_est_mode7_idx: the low/high/d dot products are exact-integer f32
//   chains (plain ops, < 2^24); scale = div_exact(n-1, high-low), inv_n = recip_exact(n-1);
//   high == low short-circuits to err 0, mirroring the Rust NaN-sticky total
//   (0 * inf -> NaN through every pixel, then NaN as i64 == 0). The Rust unweighted
//   branches fold into the weighted formula with w == 1 (1.0-mul is an exact identity);
//   mode7 zeroes the weights to 1 when perceptual, mirroring the !perceptual gate.
// - estimate_partition / estimate_partition_list: single-lane restructure of the SIMD_W
//   group fns (S3 lane-independence verdict) reading the bound ParamsGpu; SolutionList
//   insert-sort on u64 (vec2<u32>) errs, SOL_CAP 8, THRESH 4 checkerboard early-out.
// - PartitionPlan bools travel as u32; WGSL zero-init == PartitionPlan::new().
// - mode_tree block_features/predict are exact integer fixed-point; apply_mode_tree_hint
//   returns a hint code (0 none / 1 mode5 / 2 mode6) and hinted_params_word applies it to
//   the ParamsGpu words (36 use_mode4, 37 use_mode5, 38 use_mode6, 39 use_mode7).
// Test streams: estpart in-stride 89 (op mode w[4] perceptual num max_sol idxs[16] px[64])
// out 25 (op3 SolutionList = 8x(index err.lo err.hi) + len; others zero-padded);
// plans in 64 out 106 (part0 part13 part2 use13 use2 use0 list13 list2 list0 list7);
// modetree in 65 out 55 (op0: feat[10] mode conf hint hinted_params[42]; op1: mode conf).

const SOL_CAP: u32 = 8u;
const EST_THRESH: i32 = 4;

struct Solution {
    index: u32,
    err: vec2<u32>,
}

struct SolutionList {
    sols: array<Solution, 8>,
    len: u32,
}

struct PartitionPlan {
    part0: u32,
    part13: u32,
    part2: u32,
    use_list13: u32,
    use_list2: u32,
    use_list0: u32,
    list13: SolutionList,
    list2: SolutionList,
    list0: SolutionList,
    list7: SolutionList,
}

fn make_est_params(mode: u32) -> CCParams {
    var p = ccparams_clear();
    p.sel_table = select(1u, 0u, G_COLOR_INDEX_BITCOUNT[mode] == 2u);
    p.num_selector_weights = 1u << G_COLOR_INDEX_BITCOUNT[mode];
    var w = vec4<u32>(params.weights[0], params.weights[1], params.weights[2], params.weights[3]);
    if (mode >= 6u) {
        w = w * vec4<u32>(
            params.mode67_weight_mul[0],
            params.mode67_weight_mul[1],
            params.mode67_weight_mul[2],
            params.mode67_weight_mul[3],
        );
    }
    p.weights = w;
    p.perceptual = params.perceptual != 0u;
    return p;
}

fn ccc_est_idx(
    mode: u32,
    w: vec4<u32>,
    idxs: ptr<function, array<i32, 16>>,
    num: u32,
    px: ptr<function, array<vec4<i32>, 16>>,
) -> vec2<u32> {
    var lo = vec3<f32>(255.0, 255.0, 255.0);
    var hi = vec3<f32>(0.0, 0.0, 0.0);
    for (var k = 0u; k < num; k = k + 1u) {
        let c = vec3<f32>((*px)[u32((*idxs)[k])].xyz);
        lo = min(lo, c);
        hi = max(hi, c);
    }
    let nf = f32(1u << G_COLOR_INDEX_BITCOUNT[mode]);
    let dir = hi - lo;
    let low = dir.x * lo.x + dir.y * lo.y + dir.z * lo.z;
    let high = dir.x * hi.x + dir.y * hi.y + dir.z * hi.z;
    if (high == low) {
        return vec2<u32>(0u, 0u);
    }
    let scale = div_exact(nf - 1.0, high - low);
    let inv_n = recip_exact(nf - 1.0);
    let wf = vec3<f32>(f32(w.x), f32(w.y), f32(w.z));
    var total_errf = 0.0;
    for (var k = 0u; k < num; k = k + 1u) {
        let c = vec3<f32>((*px)[u32((*idxs)[k])].xyz);
        let d = dir.x * c.x + dir.y * c.y + dir.z * c.z;
        let s = fsaturate(pmul(floor(pmul(d - low, scale) + 0.5), inv_n));
        let it = padd3(lo, pmul3(s, dir));
        let dv = it - c;
        let term = padd(
            padd(pmul(pmul(wf.x, dv.x), dv.x), pmul(pmul(wf.y, dv.y), dv.y)),
            pmul(pmul(wf.z, dv.z), dv.z),
        );
        total_errf = padd(total_errf, term);
    }
    return f32_to_u64(total_errf);
}

fn ccc_est_mode7_idx(
    w: vec4<u32>,
    perceptual: bool,
    idxs: ptr<function, array<i32, 16>>,
    num: u32,
    px: ptr<function, array<vec4<i32>, 16>>,
) -> vec2<u32> {
    var lo = vec4<f32>(255.0, 255.0, 255.0, 255.0);
    var hi = vec4<f32>(0.0, 0.0, 0.0, 0.0);
    for (var k = 0u; k < num; k = k + 1u) {
        let c = vec4<f32>((*px)[u32((*idxs)[k])]);
        lo = min(lo, c);
        hi = max(hi, c);
    }
    let dir = hi - lo;
    let low = dir.x * lo.x + dir.y * lo.y + dir.z * lo.z + dir.w * lo.w;
    let high = dir.x * hi.x + dir.y * hi.y + dir.z * hi.z + dir.w * hi.w;
    if (high == low) {
        return vec2<u32>(0u, 0u);
    }
    let scale = div_exact(3.0, high - low);
    let inv_n = recip_exact(3.0);
    var wf = vec4<f32>(f32(w.x), f32(w.y), f32(w.z), f32(w.w));
    if (perceptual) {
        wf = vec4<f32>(1.0, 1.0, 1.0, 1.0);
    }
    var total_errf = 0.0;
    for (var k = 0u; k < num; k = k + 1u) {
        let c = vec4<f32>((*px)[u32((*idxs)[k])]);
        let d = dir.x * c.x + dir.y * c.y + dir.z * c.z + dir.w * c.w;
        let s = fsaturate(pmul(floor(pmul(d - low, scale) + 0.5), inv_n));
        let it = padd4(lo, pmul4(s, dir));
        let dv = it - c;
        let term = padd(
            padd(
                padd(pmul(pmul(wf.x, dv.x), dv.x), pmul(pmul(wf.y, dv.y), dv.y)),
                pmul(pmul(wf.z, dv.z), dv.z),
            ),
            pmul(pmul(wf.w, dv.w), dv.w),
        );
        total_errf = padd(total_errf, term);
    }
    return f32_to_u64(total_errf);
}

fn est_subset_err(
    mode: u32,
    p: CCParams,
    idxs: ptr<function, array<i32, 16>>,
    num: u32,
    px: ptr<function, array<vec4<i32>, 16>>,
) -> vec2<u32> {
    if (mode == 7u) {
        return ccc_est_mode7_idx(p.weights, p.perceptual, idxs, num, px);
    }
    return ccc_est_idx(mode, p.weights, idxs, num, px);
}

fn subset_total(subsets3: bool, part: u32, subset: u32) -> u32 {
    if (subsets3) {
        return SUBSET_IDX3_TOTAL[part * 3u + subset];
    }
    return SUBSET_IDX2_TOTAL[part * 3u + subset];
}

fn load_subset_idxs(subsets3: bool, part: u32, subset: u32, idxs: ptr<function, array<i32, 16>>) {
    let base = (part * 3u + subset) * 16u;
    if (subsets3) {
        for (var i = 0u; i < 16u; i = i + 1u) {
            (*idxs)[i] = SUBSET_IDX3_IDX[base + i];
        }
    } else {
        for (var i = 0u; i < 16u; i = i + 1u) {
            (*idxs)[i] = SUBSET_IDX2_IDX[base + i];
        }
    }
}

fn estimate_partition(mode: u32, px: ptr<function, array<vec4<i32>, 16>>) -> u32 {
    let total_subsets = G_NUM_SUBSETS[mode];
    let total_partitions = min(params.max_partitions_mode[mode], 1u << G_PARTITION_BITS[mode]);
    if (total_partitions <= 1u) {
        return 0u;
    }
    let p = make_est_params(mode);
    let subsets3 = total_subsets == 3u;
    var best_err = vec2<u32>(0xffffffffu, 0xffffffffu);
    var best_partition = 0u;
    for (var part = 0u; part < total_partitions; part = part + 1u) {
        var total = vec2<u32>(0u, 0u);
        var idxs: array<i32, 16>;
        for (var subset = 0u; subset < total_subsets; subset = subset + 1u) {
            load_subset_idxs(subsets3, part, subset, &idxs);
            let err = est_subset_err(mode, p, &idxs, subset_total(subsets3, part, subset), px);
            total = add64(total, err);
            if (le64(best_err, total)) {
                break;
            }
        }
        var retired = false;
        if (lt64(total, best_err)) {
            best_err = total;
            best_partition = part;
            if (eq64(best_err, vec2<u32>(0u, 0u))) {
                retired = true;
            }
        }
        if (total_subsets == 2u
            && part == BC7E_2SUBSET_CHECKERBOARD_PARTITION_INDEX
            && best_partition != BC7E_2SUBSET_CHECKERBOARD_PARTITION_INDEX) {
            retired = true;
        }
        if (retired) {
            break;
        }
    }
    return best_partition;
}

fn est_list_range(
    mode: u32,
    subsets3: bool,
    total_subsets: u32,
    max_solutions: i32,
    part_lo: u32,
    part_hi: u32,
    px: ptr<function, array<vec4<i32>, 16>>,
    sols: ptr<function, array<Solution, 8>>,
    num_solutions: ptr<function, i32>,
) -> i32 {
    let p = make_est_params(mode);
    var i_at = 0;
    for (var part = part_lo; part < part_hi; part = part + 1u) {
        let full = *num_solutions == max_solutions;
        var thresh = vec2<u32>(0xffffffffu, 0xffffffffu);
        if (full) {
            thresh = (*sols)[u32(max_solutions - 1)].err;
        }
        var total = vec2<u32>(0u, 0u);
        var pruned = false;
        var idxs: array<i32, 16>;
        for (var subset = 0u; subset < total_subsets; subset = subset + 1u) {
            load_subset_idxs(subsets3, part, subset, &idxs);
            let err = est_subset_err(mode, p, &idxs, subset_total(subsets3, part, subset), px);
            total = add64(total, err);
            if (le64(thresh, total)) {
                pruned = true;
                break;
            }
        }
        if (pruned) {
            i_at = *num_solutions;
            continue;
        }
        var i = 0;
        for (var s = 0; s < *num_solutions; s = s + 1) {
            if (lt64(total, (*sols)[u32(s)].err)) {
                break;
            }
            i = i + 1;
        }
        if (i < *num_solutions) {
            var solutions_to_move = (max_solutions - 1) - i;
            let num_elements_at_i = *num_solutions - i;
            if (solutions_to_move > num_elements_at_i) {
                solutions_to_move = num_elements_at_i;
            }
            for (var t = 0; t < solutions_to_move; t = t + 1) {
                let j = solutions_to_move - 1 - t;
                (*sols)[u32(i + j + 1)] = (*sols)[u32(i + j)];
            }
        }
        if (*num_solutions < max_solutions) {
            *num_solutions = *num_solutions + 1;
        }
        if (i < *num_solutions) {
            (*sols)[u32(i)].err = total;
            (*sols)[u32(i)].index = part;
        }
        i_at = i;
    }
    return i_at;
}

fn est_list_take(
    sols: ptr<function, array<Solution, 8>>,
    num_solutions: i32,
    max_solutions_in: i32,
) -> SolutionList {
    var lst: SolutionList;
    var take = num_solutions;
    if (take > max_solutions_in) {
        take = max_solutions_in;
    }
    if (take < 0) {
        take = 0;
    }
    for (var k = 0; k < take; k = k + 1) {
        lst.sols[u32(k)] = (*sols)[u32(k)];
    }
    lst.len = u32(take);
    return lst;
}

fn est_list_prefix(total_partitions: u32) -> SolutionList {
    var lst: SolutionList;
    let take = min(total_partitions, SOL_CAP);
    for (var i = 0u; i < take; i = i + 1u) {
        lst.sols[i].index = i;
        lst.sols[i].err = vec2<u32>(i, 0u);
    }
    lst.len = take;
    return lst;
}

fn estimate_partition_list(
    mode: u32,
    max_solutions_in: i32,
    px: ptr<function, array<vec4<i32>, 16>>,
) -> SolutionList {
    var lst: SolutionList;
    let total_subsets = G_NUM_SUBSETS[mode];
    let total_partitions = min(params.max_partitions_mode[mode], 1u << G_PARTITION_BITS[mode]);
    if (total_partitions <= 1u) {
        lst.sols[0].index = 0u;
        lst.sols[0].err = vec2<u32>(0u, 0u);
        lst.len = 1u;
        return lst;
    }
    if (max_solutions_in >= i32(total_partitions)) {
        return est_list_prefix(total_partitions);
    }
    var max_solutions = max_solutions_in;
    if (total_subsets == 2u && max_solutions < EST_THRESH) {
        max_solutions = EST_THRESH;
    }
    if (max_solutions > i32(SOL_CAP)) {
        max_solutions = i32(SOL_CAP);
    }
    let subsets3 = total_subsets == 3u;
    var sols: array<Solution, 8>;
    var num_solutions = 0;
    if (total_subsets == 2u) {
        let first_end = min(total_partitions, BC7E_2SUBSET_CHECKERBOARD_PARTITION_INDEX + 1u);
        let ia = est_list_range(
            mode, subsets3, total_subsets, max_solutions,
            0u, first_end, px, &sols, &num_solutions,
        );
        if (total_partitions > first_end && ia < EST_THRESH) {
            _ = est_list_range(
                mode, subsets3, total_subsets, max_solutions,
                first_end, total_partitions, px, &sols, &num_solutions,
            );
        }
    } else {
        _ = est_list_range(
            mode, subsets3, total_subsets, max_solutions,
            0u, total_partitions, px, &sols, &num_solutions,
        );
    }
    return est_list_take(&sols, num_solutions, max_solutions_in);
}

fn est_list_group2(
    mode: u32,
    max_solutions_in: i32,
    nlanes: u32,
    gpx: ptr<function, array<vec4<i32>, 64>>,
    out_lists: ptr<function, array<SolutionList, 4>>,
) {
    let total_partitions = min(params.max_partitions_mode[mode], 1u << G_PARTITION_BITS[mode]);
    if (total_partitions <= 1u) {
        var lst: SolutionList;
        lst.sols[0].index = 0u;
        lst.sols[0].err = vec2<u32>(0u, 0u);
        lst.len = 1u;
        for (var lane = 0u; lane < nlanes; lane = lane + 1u) {
            (*out_lists)[lane] = lst;
        }
        return;
    }
    if (max_solutions_in >= i32(total_partitions)) {
        let lst = est_list_prefix(total_partitions);
        for (var lane = 0u; lane < nlanes; lane = lane + 1u) {
            (*out_lists)[lane] = lst;
        }
        return;
    }
    var max_solutions = max_solutions_in;
    if (max_solutions < EST_THRESH) {
        max_solutions = EST_THRESH;
    }
    if (max_solutions > i32(SOL_CAP)) {
        max_solutions = i32(SOL_CAP);
    }
    var gsols: array<Solution, 32>;
    var gnum: array<i32, 4>;
    var giat: array<i32, 4>;
    let first_end = min(total_partitions, BC7E_2SUBSET_CHECKERBOARD_PARTITION_INDEX + 1u);
    for (var lane = 0u; lane < nlanes; lane = lane + 1u) {
        var lpx: array<vec4<i32>, 16>;
        for (var i = 0u; i < 16u; i = i + 1u) {
            lpx[i] = (*gpx)[lane * 16u + i];
        }
        var sols: array<Solution, 8>;
        var num = 0;
        giat[lane] = est_list_range(
            mode, false, 2u, max_solutions, 0u, first_end, &lpx, &sols, &num,
        );
        for (var i = 0u; i < SOL_CAP; i = i + 1u) {
            gsols[lane * 8u + i] = sols[i];
        }
        gnum[lane] = num;
    }
    if (total_partitions > first_end) {
        var all_done = true;
        for (var lane = 0u; lane < nlanes; lane = lane + 1u) {
            if (giat[lane] < EST_THRESH) {
                all_done = false;
            }
        }
        if (!all_done) {
            for (var lane = 0u; lane < nlanes; lane = lane + 1u) {
                var lpx: array<vec4<i32>, 16>;
                for (var i = 0u; i < 16u; i = i + 1u) {
                    lpx[i] = (*gpx)[lane * 16u + i];
                }
                var sols: array<Solution, 8>;
                for (var i = 0u; i < SOL_CAP; i = i + 1u) {
                    sols[i] = gsols[lane * 8u + i];
                }
                var num = gnum[lane];
                _ = est_list_range(
                    mode, false, 2u, max_solutions,
                    first_end, total_partitions, &lpx, &sols, &num,
                );
                for (var i = 0u; i < SOL_CAP; i = i + 1u) {
                    gsols[lane * 8u + i] = sols[i];
                }
                gnum[lane] = num;
            }
        }
    }
    for (var lane = 0u; lane < nlanes; lane = lane + 1u) {
        var sols: array<Solution, 8>;
        for (var i = 0u; i < SOL_CAP; i = i + 1u) {
            sols[i] = gsols[lane * 8u + i];
        }
        (*out_lists)[lane] = est_list_take(&sols, gnum[lane], max_solutions_in);
    }
}

fn build_partition_plan(px: ptr<function, array<vec4<i32>, 16>>, include7: bool) -> PartitionPlan {
    var plan: PartitionPlan;
    if (params.use_mode[1] != 0u || params.use_mode[3] != 0u) {
        if (params.op_max_mode13 == 1u) {
            plan.part13 = estimate_partition(1u, px);
        } else {
            plan.list13 = estimate_partition_list(1u, i32(params.op_max_mode13), px);
            plan.use_list13 = 1u;
        }
    }
    if (params.use_mode[0] != 0u) {
        if (params.op_max_mode0 == 1u) {
            plan.part0 = estimate_partition(0u, px);
        } else {
            plan.list0 = estimate_partition_list(0u, i32(params.op_max_mode0), px);
            plan.use_list0 = 1u;
        }
    }
    if (params.use_mode[2] != 0u) {
        if (params.op_max_mode2 == 1u) {
            plan.part2 = estimate_partition(2u, px);
        } else {
            plan.list2 = estimate_partition_list(2u, i32(params.op_max_mode2), px);
            plan.use_list2 = 1u;
        }
    }
    if (include7 && params.use_mode7 != 0u) {
        plan.list7 = estimate_partition_list(7u, i32(params.al_max_mode7), px);
    }
    return plan;
}

fn mt_luma(r: i32, g: i32, b: i32) -> i32 {
    return (54 * r + 183 * g + 19 * b) >> 8u;
}

fn block_features(px: ptr<function, array<vec4<i32>, 16>>) -> array<i32, 10> {
    var s = vec3<i32>(0, 0, 0);
    var sqs = vec3<i32>(0, 0, 0);
    var mn = vec4<i32>(255, 255, 255, 255);
    var mx = vec4<i32>(0, 0, 0, 0);
    for (var i = 0u; i < 16u; i = i + 1u) {
        let p = (*px)[i];
        s = s + p.xyz;
        sqs = sqs + p.xyz * p.xyz;
        mn = min(mn, p);
        mx = max(mx, p);
    }
    var vr = 0;
    for (var k = 0u; k < 3u; k = k + 1u) {
        vr = vr + (sqs[k] / 16 - (s[k] / 16) * (s[k] / 16));
    }
    let var_rgb = clamp(vr, 0, 65535);
    let md = mx - mn;
    let has_alpha = select(0, 1, mn.w < 255);
    let mean = s / 16;
    let mean_luma = mt_luma(mean.x, mean.y, mean.z);
    var qmin = 2147483647;
    var qmax = bitcast<i32>(0x80000000u);
    for (var qy = 0u; qy < 2u; qy = qy + 1u) {
        for (var qx = 0u; qx < 2u; qx = qx + 1u) {
            var acc = vec3<i32>(0, 0, 0);
            for (var dy = 0u; dy < 2u; dy = dy + 1u) {
                for (var dx = 0u; dx < 2u; dx = dx + 1u) {
                    acc = acc + (*px)[(qy * 2u + dy) * 4u + (qx * 2u + dx)].xyz;
                }
            }
            let ql = mt_luma(acc.x / 4, acc.y / 4, acc.z / 4);
            qmin = min(qmin, ql);
            qmax = max(qmax, ql);
        }
    }
    var feat: array<i32, 10>;
    feat[0] = var_rgb;
    feat[1] = md.x;
    feat[2] = md.y;
    feat[3] = md.z;
    feat[4] = md.w;
    feat[5] = has_alpha;
    feat[6] = mn.w;
    feat[7] = mx.w;
    feat[8] = qmax - qmin;
    feat[9] = mean_luma;
    return feat;
}

fn mt_predict(feat: ptr<function, array<i32, 10>>) -> vec2<i32> {
    var idx = 0;
    for (var guard = 0u; guard < 127u; guard = guard + 1u) {
        let f = TREE_FEATURE[u32(idx)];
        if (f < 0) {
            return vec2<i32>(TREE_LEFT[u32(idx)], TREE_RIGHT[u32(idx)]);
        }
        if ((*feat)[u32(f)] <= TREE_THRESHOLD[u32(idx)]) {
            idx = TREE_LEFT[u32(idx)];
        } else {
            idx = TREE_RIGHT[u32(idx)];
        }
    }
    return vec2<i32>(0, 0);
}

fn apply_mode_tree_hint(px: ptr<function, array<vec4<i32>, 16>>) -> u32 {
    var feat = block_features(px);
    let pr = mt_predict(&feat);
    if (pr.y < 9000) {
        return 0u;
    }
    if (pr.x == 5) {
        return 1u;
    }
    if (pr.x == 6 && feat[0] >= 200 && feat[1] >= 16) {
        return 2u;
    }
    return 0u;
}

fn hinted_params_word(i: u32, hint: u32) -> u32 {
    if (hint == 1u && (i == 36u || i == 38u || i == 39u)) {
        return 0u;
    }
    if (hint == 2u && (i == 36u || i == 37u || i == 39u)) {
        return 0u;
    }
    return params_word(i);
}

fn write_sol_list(ob: u32, lst: SolutionList) {
    for (var i = 0u; i < SOL_CAP; i = i + 1u) {
        out_words[ob + i * 3u] = lst.sols[i].index;
        out_words[ob + i * 3u + 1u] = lst.sols[i].err.x;
        out_words[ob + i * 3u + 2u] = lst.sols[i].err.y;
    }
    out_words[ob + 24u] = lst.len;
}

@compute @workgroup_size(256)
fn bc7_test_est_partition(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * 89u;
    let ob = gid * 25u;
    let op = blocks[ib];
    let mode = blocks[ib + 1u];
    let w = vec4<u32>(blocks[ib + 2u], blocks[ib + 3u], blocks[ib + 4u], blocks[ib + 5u]);
    let perceptual = blocks[ib + 6u] != 0u;
    let num = blocks[ib + 7u];
    let max_sol = bitcast<i32>(blocks[ib + 8u]);
    var idxs: array<i32, 16>;
    for (var i = 0u; i < 16u; i = i + 1u) {
        idxs[i] = bitcast<i32>(blocks[ib + 9u + i]);
    }
    var px: array<vec4<i32>, 16>;
    for (var i = 0u; i < 16u; i = i + 1u) {
        px[i] = in_vec4i(ib + 25u + i * 4u);
    }
    if (op == 0u) {
        let e = ccc_est_idx(mode, w, &idxs, num, &px);
        out_words[ob] = e.x;
        out_words[ob + 1u] = e.y;
        return;
    }
    if (op == 1u) {
        let e = ccc_est_mode7_idx(w, perceptual, &idxs, num, &px);
        out_words[ob] = e.x;
        out_words[ob + 1u] = e.y;
        return;
    }
    if (op == 2u) {
        out_words[ob] = estimate_partition(mode, &px);
        return;
    }
    if (op == 3u) {
        write_sol_list(ob, estimate_partition_list(mode, max_sol, &px));
        return;
    }
    let p = make_est_params(mode);
    out_words[ob] = p.weights.x;
    out_words[ob + 1u] = p.weights.y;
    out_words[ob + 2u] = p.weights.z;
    out_words[ob + 3u] = p.weights.w;
    out_words[ob + 4u] = p.num_selector_weights;
    out_words[ob + 5u] = p.sel_table;
    out_words[ob + 6u] = select(0u, 1u, p.perceptual);
}

@compute @workgroup_size(256)
fn bc7_test_plans(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * 64u;
    let ob = gid * 106u;
    var px: array<vec4<i32>, 16>;
    for (var i = 0u; i < 16u; i = i + 1u) {
        px[i] = in_vec4i(ib + i * 4u);
    }
    let plan = build_partition_plan(&px, true);
    out_words[ob] = plan.part0;
    out_words[ob + 1u] = plan.part13;
    out_words[ob + 2u] = plan.part2;
    out_words[ob + 3u] = plan.use_list13;
    out_words[ob + 4u] = plan.use_list2;
    out_words[ob + 5u] = plan.use_list0;
    write_sol_list(ob + 6u, plan.list13);
    write_sol_list(ob + 31u, plan.list2);
    write_sol_list(ob + 56u, plan.list0);
    write_sol_list(ob + 81u, plan.list7);
}

@compute @workgroup_size(256)
fn bc7_test_modetree(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * 65u;
    let ob = gid * 55u;
    let op = blocks[ib];
    if (op == 1u) {
        var feat: array<i32, 10>;
        for (var i = 0u; i < 10u; i = i + 1u) {
            feat[i] = bitcast<i32>(blocks[ib + 1u + i]);
        }
        let pr = mt_predict(&feat);
        out_words[ob] = bitcast<u32>(pr.x);
        out_words[ob + 1u] = bitcast<u32>(pr.y);
        return;
    }
    var px: array<vec4<i32>, 16>;
    for (var i = 0u; i < 16u; i = i + 1u) {
        px[i] = in_vec4i(ib + 1u + i * 4u);
    }
    var feat = block_features(&px);
    for (var i = 0u; i < 10u; i = i + 1u) {
        out_words[ob + i] = bitcast<u32>(feat[i]);
    }
    let pr = mt_predict(&feat);
    out_words[ob + 10u] = bitcast<u32>(pr.x);
    out_words[ob + 11u] = bitcast<u32>(pr.y);
    let hint = apply_mode_tree_hint(&px);
    out_words[ob + 12u] = hint;
    for (var i = 0u; i < 42u; i = i + 1u) {
        out_words[ob + 13u + i] = hinted_params_word(i, hint);
    }
}

// Bit packing + solid handler + alpha mode4/5. Contract vs bc7.rs:
// - OptResults usize fields travel as u32; a finished 16-byte block is vec4<u32> of LE
//   words with a byte-addressed OR helper, so set_block_bits mirrors the Rust byte loop
//   (including the `as u8` truncation of val << (ofs & 7)).
// - encode_bc7_block_mode6 builds the two u64 halves as vec2<u32> via or64_shl (v < 2^8,
//   0 <= s <= 63); bits shifted past 63 drop exactly as in Rust u64 shl.
// - handle_alpha_block_mode4/5 read cp knobs (mode4_index_mask, uber_level, perceptual,
//   pbit_search, refinement_passes, uber1_mask) from the bound ParamsGpu; only the
//   caller's weights survive into the CCParams they receive. Alpha-selector scans are
//   exact-integer u64 accumulations (mul32x32_64/add64). The two Rust float sites:
//   mode4 pins 63/255 as MODE4_SCALE_BITS and routes mul->add through pmul/padd; mode5's
//   xl + 0.5 pins the lsq result grouping with pval before the add. The mode4 lsq keeps
//   the Rust table quirk (index_selector != 0 -> G_WEIGHTS2X else G_WEIGHTS3X).
// Test streams: encbits in-stride 67 (op mode partition rotation index_selector sel[16]
// asel[16] low[12] high[12] pbits[6]; op 1 = mode6 encoder) out 4; solid in 4 (cr cg cb
// ca) out 4; mode4 in 72 (w[4] lo_a hi_a init_err[2] px[64]) out 43 (err[2]
// index_selector low0[4] high0[4] sel[16] asel[16]); mode5 in 70 (w[4] lo_a hi_a px[64])
// out 43.

struct OptResults {
    mode: u32,
    partn: u32,
    selectors: array<i32, 16>,
    alpha_selectors: array<i32, 16>,
    low: array<vec4<i32>, 3>,
    high: array<vec4<i32>, 3>,
    pbits: array<vec2<u32>, 3>,
    rotation: u32,
    index_selector: u32,
}

const MODE4_SCALE_BITS: u32 = 0x3e7cfcfdu;

fn get_color_index_size(mode: u32, index_selector: u32) -> u32 {
    return G_COLOR_INDEX_BITCOUNT[mode] + index_selector;
}

fn get_alpha_index_size(mode: u32, index_selector: u32) -> u32 {
    return u32(G_ALPHA_INDEX_BITCOUNT[mode] - i32(index_selector));
}

fn mode_has_separate_alpha_selectors(mode: u32) -> bool {
    return mode == 4u || mode == 5u;
}

fn block_or_byte(blk: ptr<function, vec4<u32>>, byte_idx: u32, v: u32) {
    (*blk)[byte_idx >> 2u] = (*blk)[byte_idx >> 2u] | ((v & 0xffu) << ((byte_idx & 3u) * 8u));
}

fn set_block_bits(
    blk: ptr<function, vec4<u32>>,
    val: u32,
    num_bits: u32,
    cur_ofs: ptr<function, u32>,
) {
    var v = val;
    var nb = num_bits;
    while (nb != 0u) {
        let n = min(8u - (*cur_ofs & 7u), nb);
        block_or_byte(blk, *cur_ofs >> 3u, v << (*cur_ofs & 7u));
        v = v >> n;
        nb = nb - n;
        *cur_ofs = *cur_ofs + n;
    }
}

fn encode_bc7_block_bits(res: ptr<function, OptResults>) -> vec4<u32> {
    let best_mode = (*res).mode;
    let total_subsets = G_NUM_SUBSETS[best_mode];
    let total_partitions = 1u << G_PARTITION_BITS[best_mode];
    var color_selectors: array<i32, 16>;
    var alpha_selectors: array<i32, 16>;
    var part: array<u32, 16>;
    for (var i = 0u; i < 16u; i = i + 1u) {
        color_selectors[i] = (*res).selectors[i];
        alpha_selectors[i] = (*res).alpha_selectors[i];
        if (total_subsets == 2u) {
            part[i] = G_PARTITION2[(*res).partn * 16u + i];
        } else if (total_subsets == 3u) {
            part[i] = G_PARTITION3[(*res).partn * 16u + i];
        } else {
            part[i] = 0u;
        }
    }
    var low: array<vec4<i32>, 3>;
    var high: array<vec4<i32>, 3>;
    var pbits: array<vec2<u32>, 3>;
    for (var k = 0u; k < 3u; k = k + 1u) {
        low[k] = (*res).low[k];
        high[k] = (*res).high[k];
        pbits[k] = (*res).pbits[k];
    }
    var anchor = vec3<i32>(-1);
    for (var k = 0u; k < total_subsets; k = k + 1u) {
        var anchor_index = 0u;
        if (k != 0u) {
            if (total_subsets == 3u && k == 1u) {
                anchor_index = u32(G_ANCHOR_3RD_1[(*res).partn]);
            } else if (total_subsets == 3u && k == 2u) {
                anchor_index = u32(G_ANCHOR_3RD_2[(*res).partn]);
            } else {
                anchor_index = u32(G_ANCHOR_2ND[(*res).partn]);
            }
        }
        anchor[k] = i32(anchor_index);
        let color_index_bits = get_color_index_size(best_mode, (*res).index_selector);
        let num_color_indices = i32(1u << color_index_bits);
        if ((color_selectors[anchor_index] & (num_color_indices >> 1u)) != 0) {
            for (var i = 0u; i < 16u; i = i + 1u) {
                if (part[i] == k) {
                    color_selectors[i] = (num_color_indices - 1) - color_selectors[i];
                }
            }
            if (mode_has_separate_alpha_selectors(best_mode)) {
                for (var q = 0u; q < 3u; q = q + 1u) {
                    let t = low[k][q];
                    low[k][q] = high[k][q];
                    high[k][q] = t;
                }
            } else {
                let t = low[k];
                low[k] = high[k];
                high[k] = t;
            }
            if (G_MODE_HAS_SHARED_P_BITS[best_mode] == 0) {
                let t = pbits[k].x;
                pbits[k].x = pbits[k].y;
                pbits[k].y = t;
            }
        }
        if (mode_has_separate_alpha_selectors(best_mode)) {
            let alpha_index_bits = get_alpha_index_size(best_mode, (*res).index_selector);
            let num_alpha_indices = i32(1u << alpha_index_bits);
            if ((alpha_selectors[anchor_index] & (num_alpha_indices >> 1u)) != 0) {
                for (var i = 0u; i < 16u; i = i + 1u) {
                    if (part[i] == k) {
                        alpha_selectors[i] = (num_alpha_indices - 1) - alpha_selectors[i];
                    }
                }
                let t = low[k].w;
                low[k].w = high[k].w;
                high[k].w = t;
            }
        }
    }
    var block = vec4<u32>(0u);
    var cur = 0u;
    set_block_bits(&block, 1u << best_mode, best_mode + 1u, &cur);
    if (best_mode == 4u || best_mode == 5u) {
        set_block_bits(&block, (*res).rotation, 2u, &cur);
    }
    if (best_mode == 4u) {
        set_block_bits(&block, (*res).index_selector, 1u, &cur);
    }
    if (total_partitions > 1u) {
        set_block_bits(&block, (*res).partn, select(4u, 6u, total_partitions == 64u), &cur);
    }
    let total_comps = select(3u, 4u, best_mode >= 4u);
    for (var comp = 0u; comp < total_comps; comp = comp + 1u) {
        for (var subset = 0u; subset < total_subsets; subset = subset + 1u) {
            var prec = G_COLOR_PRECISION_TABLE[best_mode];
            if (comp == 3u) {
                prec = G_ALPHA_PRECISION_TABLE[best_mode];
            }
            set_block_bits(&block, bitcast<u32>(low[subset][comp]), prec, &cur);
            set_block_bits(&block, bitcast<u32>(high[subset][comp]), prec, &cur);
        }
    }
    if (G_MODE_HAS_P_BITS[best_mode] != 0) {
        for (var subset = 0u; subset < total_subsets; subset = subset + 1u) {
            set_block_bits(&block, pbits[subset].x, 1u, &cur);
            if (G_MODE_HAS_SHARED_P_BITS[best_mode] == 0) {
                set_block_bits(&block, pbits[subset].y, 1u, &cur);
            }
        }
    }
    for (var idx = 0; idx < 16; idx = idx + 1) {
        var n = get_color_index_size(best_mode, (*res).index_selector);
        if ((*res).index_selector != 0u) {
            n = get_alpha_index_size(best_mode, (*res).index_selector);
        }
        if (idx == anchor.x || idx == anchor.y || idx == anchor.z) {
            n = n - 1u;
        }
        var val = color_selectors[idx];
        if ((*res).index_selector != 0u) {
            val = alpha_selectors[idx];
        }
        set_block_bits(&block, bitcast<u32>(val), n, &cur);
    }
    if (mode_has_separate_alpha_selectors(best_mode)) {
        for (var idx = 0; idx < 16; idx = idx + 1) {
            var n = get_alpha_index_size(best_mode, (*res).index_selector);
            if ((*res).index_selector != 0u) {
                n = get_color_index_size(best_mode, (*res).index_selector);
            }
            if (idx == anchor.x || idx == anchor.y || idx == anchor.z) {
                n = n - 1u;
            }
            var val = alpha_selectors[idx];
            if ((*res).index_selector != 0u) {
                val = color_selectors[idx];
            }
            set_block_bits(&block, bitcast<u32>(val), n, &cur);
        }
    }
    return block;
}

fn or64_shl(acc: vec2<u32>, v: u32, s: u32) -> vec2<u32> {
    if (s == 0u) {
        return vec2<u32>(acc.x | v, acc.y);
    }
    if (s < 32u) {
        return vec2<u32>(acc.x | (v << s), acc.y | (v >> (32u - s)));
    }
    return vec2<u32>(acc.x, acc.y | (v << (s - 32u)));
}

fn encode_bc7_block_mode6(res: ptr<function, OptResults>) -> vec4<u32> {
    var low: vec4<i32>;
    var high: vec4<i32>;
    var pb: vec2<u32>;
    var invert_selectors = 0u;
    if (((*res).selectors[0] & 8) != 0) {
        invert_selectors = 15u;
        low = (*res).high[0];
        high = (*res).low[0];
        pb = vec2<u32>((*res).pbits[0].y, (*res).pbits[0].x);
    } else {
        low = (*res).low[0];
        high = (*res).high[0];
        pb = (*res).pbits[0];
    }
    var l = vec2<u32>(1u << 6u, 0u);
    l = or64_shl(l, bitcast<u32>(low.x), 7u);
    l = or64_shl(l, bitcast<u32>(high.x), 14u);
    l = or64_shl(l, bitcast<u32>(low.y), 21u);
    l = or64_shl(l, bitcast<u32>(high.y), 28u);
    l = or64_shl(l, bitcast<u32>(low.z), 35u);
    l = or64_shl(l, bitcast<u32>(high.z), 42u);
    l = or64_shl(l, bitcast<u32>(low.w), 49u);
    l = or64_shl(l, bitcast<u32>(high.w), 56u);
    l = or64_shl(l, pb.x, 63u);
    var h = vec2<u32>(pb.y, 0u);
    for (var i = 0u; i < 16u; i = i + 1u) {
        let v = invert_selectors ^ bitcast<u32>((*res).selectors[i]);
        var shift = i * 4u;
        if (i == 0u) {
            shift = 1u;
        }
        h = or64_shl(h, v, shift);
    }
    return vec4<u32>(l.x, l.y, h.x, h.y);
}

fn handle_block_solid(cr: u32, cg: u32, cb: u32, ca: i32) -> vec4<u32> {
    let er = opt_tables[OPT_MODE5_OFF + cr];
    let eg = opt_tables[OPT_MODE5_OFF + cg];
    let eb = opt_tables[OPT_MODE5_OFF + cb];
    var opt: OptResults;
    opt.mode = 5u;
    opt.low[0] = vec4<i32>(i32(er & 0xffu), i32(eg & 0xffu), i32(eb & 0xffu), ca);
    opt.high[0] = vec4<i32>(i32(er >> 8u), i32(eg >> 8u), i32(eb >> 8u), ca);
    for (var i = 0u; i < 16u; i = i + 1u) {
        opt.selectors[i] = i32(MODE5_IDX);
        opt.alpha_selectors[i] = 0;
    }
    return encode_bc7_block_bits(&opt);
}

fn mode4_alpha_vals(index_selector: u32, la: i32, ha: i32, vals: ptr<function, array<i32, 8>>) {
    if (index_selector == 0u) {
        (*vals)[0] = (la << 2u) | (la >> 4u);
        (*vals)[7] = (ha << 2u) | (ha >> 4u);
        for (var i = 1u; i < 7u; i = i + 1u) {
            let w = i32(G_WEIGHTS3[i]);
            (*vals)[i] = ((*vals)[0] * (64 - w) + (*vals)[7] * w + 32) >> 6u;
        }
    } else {
        (*vals)[0] = (la << 2u) | (la >> 4u);
        (*vals)[3] = (ha << 2u) | (ha >> 4u);
        (*vals)[1] = ((*vals)[0] * (64 - 21) + (*vals)[3] * 21 + 32) >> 6u;
        (*vals)[2] = ((*vals)[0] * (64 - 43) + (*vals)[3] * 43 + 32) >> 6u;
    }
}

fn mode4_alpha_scan(
    index_selector: u32,
    vals: ptr<function, array<i32, 8>>,
    w3: u32,
    pixels: ptr<function, array<vec4<i32>, 16>>,
    sel: ptr<function, array<i32, 16>>,
) -> vec2<u32> {
    var total = vec2<u32>(0u, 0u);
    var count = 8u;
    if (index_selector != 0u) {
        count = 4u;
    }
    for (var i = 0u; i < 16u; i = i + 1u) {
        let a = (*pixels)[i].w;
        var s = 0;
        var be = iabs32(a - (*vals)[0]);
        for (var j = 1u; j < count; j = j + 1u) {
            let e = iabs32(a - (*vals)[j]);
            if (e < be) {
                be = e;
                s = i32(j);
            }
        }
        total = add64(total, mul32x32_64(u32(be * be), w3));
        (*sel)[i] = s;
    }
    return total;
}

fn handle_alpha_block_mode4(
    pixels: ptr<function, array<vec4<i32>, 16>>,
    p_in: CCParams,
    lo_a: i32,
    hi_a: i32,
    opt4: ptr<function, OptResults>,
    mode4_err: ptr<function, vec2<u32>>,
) {
    var p = p_in;
    p.has_alpha = false;
    p.comp_bits = 5u;
    p.has_pbits = false;
    p.endpoints_share_pbit = false;
    p.perceptual = params.perceptual != 0u;
    for (var index_selector = 0u; index_selector < 2u; index_selector = index_selector + 1u) {
        if ((params.mode4_index_mask & (1u << index_selector)) == 0u) {
            continue;
        }
        if (index_selector != 0u) {
            p.sel_table = 1u;
            p.num_selector_weights = 8u;
        } else {
            p.sel_table = 0u;
            p.num_selector_weights = 4u;
        }
        var results = ccresults_new();
        let trial_err_color = color_cell_compression(
            4u, p, &results,
            params.pbit_search != 0u, params.refinement_passes,
            params.uber_level, params.uber1_mask,
            16u, pixels, true,
        );
        var la = min((lo_a + 2) >> 2u, 63);
        var ha = min((hi_a + 2) >> 2u, 63);
        if (la == ha && lo_a != hi_a) {
            if (ha != 63) {
                ha = ha + 1;
            } else if (la != 0) {
                la = la - 1;
            }
        }
        var best_alpha_err = U64_MAX;
        var best_la = 0;
        var best_ha = 0;
        var best_alpha_selectors: array<i32, 16>;
        for (var pss = 0u; pss < 2u; pss = pss + 1u) {
            var vals: array<i32, 8>;
            mode4_alpha_vals(index_selector, la, ha, &vals);
            var trial_alpha_selectors: array<i32, 16>;
            let trial_alpha_err =
                mode4_alpha_scan(index_selector, &vals, p.weights.w, pixels, &trial_alpha_selectors);
            if (lt64(trial_alpha_err, best_alpha_err)) {
                best_alpha_err = trial_alpha_err;
                best_la = la;
                best_ha = ha;
                for (var i = 0u; i < 16u; i = i + 1u) {
                    best_alpha_selectors[i] = trial_alpha_selectors[i];
                }
            }
            if (pss == 0u) {
                var xl = 0.0;
                var xh = 0.0;
                var swt = 1u;
                if (index_selector != 0u) {
                    swt = 0u;
                }
                compute_lsq_endpoints_a(16u, &trial_alpha_selectors, swt, &xl, &xh, pixels);
                if (xl > xh) {
                    let t = xl;
                    xl = xh;
                    xh = t;
                }
                let scale = bitcast<f32>(MODE4_SCALE_BITS);
                la = clamp(itrunc(floor(padd(pmul(xl, scale), 0.5))), 0, 63);
                ha = clamp(itrunc(floor(padd(pmul(xh, scale), 0.5))), 0, 63);
            }
        }
        if (params.uber_level > 0u) {
            let d = min(i32(params.uber_level), 3);
            for (var ld = -d; ld <= d; ld = ld + 1) {
                for (var hd = -d; hd <= d; hd = hd + 1) {
                    la = clamp(best_la + ld, 0, 63);
                    ha = clamp(best_ha + hd, 0, 63);
                    var vals: array<i32, 8>;
                    mode4_alpha_vals(index_selector, la, ha, &vals);
                    var trial_alpha_selectors: array<i32, 16>;
                    let trial_alpha_err = mode4_alpha_scan(
                        index_selector, &vals, p.weights.w, pixels, &trial_alpha_selectors,
                    );
                    if (lt64(trial_alpha_err, best_alpha_err)) {
                        best_alpha_err = trial_alpha_err;
                        best_la = la;
                        best_ha = ha;
                        for (var i = 0u; i < 16u; i = i + 1u) {
                            best_alpha_selectors[i] = trial_alpha_selectors[i];
                        }
                    }
                }
            }
        }
        let trial_err = add64(trial_err_color, best_alpha_err);
        if (lt64(trial_err, *mode4_err)) {
            *mode4_err = trial_err;
            (*opt4).mode = 4u;
            (*opt4).index_selector = index_selector;
            (*opt4).rotation = 0u;
            (*opt4).partn = 0u;
            (*opt4).low[0] = results.low;
            (*opt4).high[0] = results.high;
            (*opt4).low[0].w = best_la;
            (*opt4).high[0].w = best_ha;
            for (var i = 0u; i < 16u; i = i + 1u) {
                (*opt4).selectors[i] = results.selectors[i];
                (*opt4).alpha_selectors[i] = best_alpha_selectors[i];
            }
        }
    }
}

fn mode5_alpha_vals(lo_a: i32, hi_a: i32, vals: ptr<function, array<i32, 4>>) {
    (*vals)[0] = lo_a;
    (*vals)[3] = hi_a;
    (*vals)[1] = ((*vals)[0] * (64 - 21) + (*vals)[3] * 21 + 32) >> 6u;
    (*vals)[2] = ((*vals)[0] * (64 - 43) + (*vals)[3] * 43 + 32) >> 6u;
}

fn mode5_alpha_scan(
    vals: ptr<function, array<i32, 4>>,
    w3: u32,
    pixels: ptr<function, array<vec4<i32>, 16>>,
    sel: ptr<function, array<i32, 16>>,
) -> vec2<u32> {
    var total = vec2<u32>(0u, 0u);
    for (var i = 0u; i < 16u; i = i + 1u) {
        let a = (*pixels)[i].w;
        var s = 0;
        var be = iabs32(a - (*vals)[0]);
        for (var j = 1u; j < 4u; j = j + 1u) {
            let e = iabs32(a - (*vals)[j]);
            if (e < be) {
                be = e;
                s = i32(j);
            }
        }
        (*sel)[i] = s;
        total = add64(total, mul32x32_64(u32(be * be), w3));
    }
    return total;
}

fn handle_alpha_block_mode5(
    pixels: ptr<function, array<vec4<i32>, 16>>,
    p_in: CCParams,
    lo_a_in: i32,
    hi_a_in: i32,
    opt5: ptr<function, OptResults>,
) -> vec2<u32> {
    var p = p_in;
    p.sel_table = 0u;
    p.num_selector_weights = 4u;
    p.comp_bits = 7u;
    p.has_alpha = false;
    p.has_pbits = false;
    p.endpoints_share_pbit = false;
    p.perceptual = params.perceptual != 0u;
    var lo_a = lo_a_in;
    var hi_a = hi_a_in;
    var results5 = ccresults_new();
    var mode5_err = color_cell_compression(
        5u, p, &results5,
        params.pbit_search != 0u, params.refinement_passes,
        params.uber_level, params.uber1_mask,
        16u, pixels, true,
    );
    (*opt5).low[0] = results5.low;
    (*opt5).high[0] = results5.high;
    for (var i = 0u; i < 16u; i = i + 1u) {
        (*opt5).selectors[i] = results5.selectors[i];
    }
    if (lo_a == hi_a) {
        (*opt5).low[0].w = lo_a;
        (*opt5).high[0].w = hi_a;
        for (var i = 0u; i < 16u; i = i + 1u) {
            (*opt5).alpha_selectors[i] = 0;
        }
    } else {
        var mode5_alpha_err = U64_MAX;
        for (var pss = 0u; pss < 2u; pss = pss + 1u) {
            var vals: array<i32, 4>;
            mode5_alpha_vals(lo_a, hi_a, &vals);
            var trial_alpha_selectors: array<i32, 16>;
            let trial_alpha_err =
                mode5_alpha_scan(&vals, p.weights.w, pixels, &trial_alpha_selectors);
            if (lt64(trial_alpha_err, mode5_alpha_err)) {
                mode5_alpha_err = trial_alpha_err;
                (*opt5).low[0].w = lo_a;
                (*opt5).high[0].w = hi_a;
                for (var i = 0u; i < 16u; i = i + 1u) {
                    (*opt5).alpha_selectors[i] = trial_alpha_selectors[i];
                }
            }
            if (pss == 0u) {
                var xl = 0.0;
                var xh = 0.0;
                compute_lsq_endpoints_a(16u, &trial_alpha_selectors, 0u, &xl, &xh, pixels);
                var new_lo = clamp(itrunc(floor(padd(pval(xl), 0.5))), 0, 255);
                var new_hi = clamp(itrunc(floor(padd(pval(xh), 0.5))), 0, 255);
                if (new_lo > new_hi) {
                    let t = new_lo;
                    new_lo = new_hi;
                    new_hi = t;
                }
                if (new_lo == lo_a && new_hi == hi_a) {
                    break;
                }
                lo_a = new_lo;
                hi_a = new_hi;
            }
        }
        if (params.uber_level > 0u) {
            let d = min(i32(params.uber_level), 3);
            for (var ld = -d; ld <= d; ld = ld + 1) {
                for (var hd = -d; hd <= d; hd = hd + 1) {
                    lo_a = clamp((*opt5).low[0].w + ld, 0, 255);
                    hi_a = clamp((*opt5).high[0].w + hd, 0, 255);
                    var vals: array<i32, 4>;
                    mode5_alpha_vals(lo_a, hi_a, &vals);
                    var trial_alpha_selectors: array<i32, 16>;
                    let trial_alpha_err =
                        mode5_alpha_scan(&vals, p.weights.w, pixels, &trial_alpha_selectors);
                    if (lt64(trial_alpha_err, mode5_alpha_err)) {
                        mode5_alpha_err = trial_alpha_err;
                        (*opt5).low[0].w = lo_a;
                        (*opt5).high[0].w = hi_a;
                        for (var i = 0u; i < 16u; i = i + 1u) {
                            (*opt5).alpha_selectors[i] = trial_alpha_selectors[i];
                        }
                    }
                }
            }
        }
        mode5_err = add64(mode5_err, mode5_alpha_err);
    }
    (*opt5).mode = 5u;
    (*opt5).index_selector = 0u;
    (*opt5).rotation = 0u;
    (*opt5).partn = 0u;
    return mode5_err;
}

const ENCBITS_IN_STRIDE: u32 = 67u;
const MODE4_IN_STRIDE: u32 = 72u;
const MODE5_IN_STRIDE: u32 = 70u;
const ALPHA45_OUT_STRIDE: u32 = 43u;

fn read_opt_in(ib: u32, o: ptr<function, OptResults>) {
    (*o).mode = blocks[ib];
    (*o).partn = blocks[ib + 1u];
    (*o).rotation = blocks[ib + 2u];
    (*o).index_selector = blocks[ib + 3u];
    for (var i = 0u; i < 16u; i = i + 1u) {
        (*o).selectors[i] = bitcast<i32>(blocks[ib + 4u + i]);
        (*o).alpha_selectors[i] = bitcast<i32>(blocks[ib + 20u + i]);
    }
    for (var k = 0u; k < 3u; k = k + 1u) {
        (*o).low[k] = in_vec4i(ib + 36u + k * 4u);
        (*o).high[k] = in_vec4i(ib + 48u + k * 4u);
        (*o).pbits[k] = vec2<u32>(blocks[ib + 60u + k * 2u], blocks[ib + 61u + k * 2u]);
    }
}

fn write_block(ob: u32, blk: vec4<u32>) {
    for (var i = 0u; i < 4u; i = i + 1u) {
        out_words[ob + i] = blk[i];
    }
}

@compute @workgroup_size(256)
fn bc7_test_encode_bits(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * ENCBITS_IN_STRIDE;
    let op = blocks[ib];
    var o: OptResults;
    read_opt_in(ib + 1u, &o);
    var blk: vec4<u32>;
    if (op == 1u) {
        blk = encode_bc7_block_mode6(&o);
    } else {
        blk = encode_bc7_block_bits(&o);
    }
    write_block(gid * 4u, blk);
}

@compute @workgroup_size(256)
fn bc7_test_solid(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * 4u;
    let blk = handle_block_solid(
        blocks[ib], blocks[ib + 1u], blocks[ib + 2u], bitcast<i32>(blocks[ib + 3u]),
    );
    write_block(gid * 4u, blk);
}

fn write_alpha45(ob: u32, err: vec2<u32>, o: ptr<function, OptResults>) {
    out_words[ob] = err.x;
    out_words[ob + 1u] = err.y;
    out_words[ob + 2u] = (*o).index_selector;
    for (var i = 0u; i < 4u; i = i + 1u) {
        out_words[ob + 3u + i] = bitcast<u32>((*o).low[0][i]);
        out_words[ob + 7u + i] = bitcast<u32>((*o).high[0][i]);
    }
    for (var i = 0u; i < 16u; i = i + 1u) {
        out_words[ob + 11u + i] = bitcast<u32>((*o).selectors[i]);
        out_words[ob + 27u + i] = bitcast<u32>((*o).alpha_selectors[i]);
    }
}

@compute @workgroup_size(256)
fn bc7_test_mode4(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * MODE4_IN_STRIDE;
    var p = ccparams_clear();
    p.weights = vec4<u32>(blocks[ib], blocks[ib + 1u], blocks[ib + 2u], blocks[ib + 3u]);
    let lo_a = bitcast<i32>(blocks[ib + 4u]);
    let hi_a = bitcast<i32>(blocks[ib + 5u]);
    var err = vec2<u32>(blocks[ib + 6u], blocks[ib + 7u]);
    var px: array<vec4<i32>, 16>;
    for (var i = 0u; i < 16u; i = i + 1u) {
        px[i] = in_vec4i(ib + 8u + i * 4u);
    }
    var opt: OptResults;
    handle_alpha_block_mode4(&px, p, lo_a, hi_a, &opt, &err);
    write_alpha45(gid * ALPHA45_OUT_STRIDE, err, &opt);
}

@compute @workgroup_size(256)
fn bc7_test_mode5(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let ib = gid * MODE5_IN_STRIDE;
    var p = ccparams_clear();
    p.weights = vec4<u32>(blocks[ib], blocks[ib + 1u], blocks[ib + 2u], blocks[ib + 3u]);
    let lo_a = bitcast<i32>(blocks[ib + 4u]);
    let hi_a = bitcast<i32>(blocks[ib + 5u]);
    var px: array<vec4<i32>, 16>;
    for (var i = 0u; i < 16u; i = i + 1u) {
        px[i] = in_vec4i(ib + 6u + i * 4u);
    }
    var opt: OptResults;
    let err = handle_alpha_block_mode5(&px, p, lo_a, hi_a, &opt);
    write_alpha45(gid * ALPHA45_OUT_STRIDE, err, &opt);
}

// S8 top-level handlers contract. The compress path is TWO pipelines dispatched
// back-to-back over the same buffers (the NVIDIA Vulkan compiler ICEs -- device lost,
// "driver implementation is at fault" -- on any single kernel containing BOTH the
// estimation stack and the ccc stack; each compiles fine alone):
//   bc7_plan_alpha + bc7_plan_opaque13 + bc7_plan_opaque02 (the plan pass is itself
//     three pipelines chained on one scratch buffer -- the same driver ICE hits the
//     alpha+opaque and opaque13+opaque02 est unions): one thread per GROUP of 4 blocks
//     (Meta.total = num_groups, Meta.n_items = num_blocks) -- estimation is NOT
//     lane-independent: the checkerboard early-out in bc7.rs
//     estimate_partition_list_group breaks only when ALL lanes of the class-filtered
//     group reach i_at >= 4 at partition 34, so lanes couple (est_list_group2
//     reproduces this via a per-lane 0..=34 scan + joined 35..63 tail; modes 0/2 are
//     3-subset with no early-out, so the single-lane fn is exact per lane).
//     blocks @binding(4) (16 quantize_pack LE words per block) -> out_words
//     @binding(3) = PLAN_STRIDE(110) words per block: class, lo_a, hi_a, mode-tree
//     hint, part0/part13/part2, use_list13/use_list2/use_list0, then
//     list13/list2/list0/list7 in the write_sol_list layout (24 sol words + len).
//     Buffer must be zero-initialized by the host (solid/mode6_only rows stay zero).
//   bc7_encode_blocks: one thread per BLOCK (encode IS lane-independent; Meta.total =
//     Meta.n_items = num_blocks). blocks @binding(4) + plans @binding(5) (pass-1
//     output) -> out_words @binding(3) = 4 LE words per block (the 16-byte BC7 block).
//     Specialized per class via the TRIAL_CLASS override (0 solid+mode6_only, 1 alpha,
//     2 opaque; 3 = all) -- create three pipelines and dispatch them back-to-back over
//     the same buffers so each driver compile only sees one class's trial code.
// The mode-tree hint gates use_mode4/5/6/7 through hinted_params_word for ALPHA blocks
// only, and plan lists are built from UN-hinted params, both exactly as bc7.rs
// compress_group. Opaque plans skip list7 mirroring compress_group, which never copies
// list7 for opaque lanes. compress_trials runs the Rust handler trial ORDER as a
// schedule (alpha: 4,6,5,7; opaque: 6,1,0,3,5,2,4) with one static body per trial
// kind, keeping the inline-path count low (same ICE otherwise).

const TK_MODE4: u32 = 0u;
const TK_MODE6: u32 = 1u;
const TK_MODE5: u32 = 2u;
const TK_LIST: u32 = 3u;

fn base_ccparams() -> CCParams {
    var p = ccparams_clear();
    p.weights = vec4<u32>(
        params.weights[0],
        params.weights[1],
        params.weights[2],
        params.weights[3],
    );
    return p;
}

fn mode67_mul(w: vec4<u32>) -> vec4<u32> {
    return w * vec4<u32>(
        params.mode67_weight_mul[0],
        params.mode67_weight_mul[1],
        params.mode67_weight_mul[2],
        params.mode67_weight_mul[3],
    );
}

fn rotate_weights(w: vec4<u32>, rotation: u32) -> vec4<u32> {
    if (rotation == 1u) {
        return w.wyzx;
    }
    if (rotation == 2u) {
        return w.xwzy;
    }
    if (rotation == 3u) {
        return w.xywz;
    }
    return w;
}

fn rotate_block(
    px: ptr<function, array<vec4<i32>, 16>>,
    rotation: u32,
    rp: ptr<function, array<vec4<i32>, 16>>,
    tlo: ptr<function, i32>,
    thi: ptr<function, i32>,
) {
    for (var i = 0u; i < 16u; i = i + 1u) {
        (*rp)[i] = (*px)[i];
    }
    if (rotation != 0u) {
        *tlo = 255;
        *thi = 0;
        for (var i = 0u; i < 16u; i = i + 1u) {
            var v = (*rp)[i];
            if (rotation == 1u) {
                v = v.wyzx;
            } else if (rotation == 2u) {
                v = v.xwzy;
            } else {
                v = v.xywz;
            }
            (*rp)[i] = v;
            *tlo = min(*tlo, v.w);
            *thi = max(*thi, v.w);
        }
    }
}

fn run_subsets(
    mode: u32,
    subsets3: bool,
    p: CCParams,
    num_solutions: u32,
    trial_partition: u32,
    refine_force: bool,
    best_err: ptr<function, vec2<u32>>,
    opt: ptr<function, OptResults>,
    px: ptr<function, array<vec4<i32>, 16>>,
) {
    var spi: array<u32, 48>;
    var ssel: array<i32, 48>;
    var st: array<u32, 3>;
    var slow: array<vec4<i32>, 3>;
    var shigh: array<vec4<i32>, 3>;
    var spb: array<vec2<u32>, 3>;
    var trial_err = vec2<u32>(0u, 0u);
    var ok = true;
    var total_subsets = 2u;
    if (subsets3) {
        total_subsets = 3u;
    }
    let part_base = trial_partition * 16u;
    for (var subset = 0u; subset < total_subsets; subset = subset + 1u) {
        var sub_px: array<vec4<i32>, 16>;
        var n = 0u;
        for (var idx = 0u; idx < 16u; idx = idx + 1u) {
            var pp = G_PARTITION2[part_base + idx];
            if (subsets3) {
                pp = G_PARTITION3[part_base + idx];
            }
            if (pp == subset) {
                sub_px[n] = (*px)[idx];
                spi[subset * 16u + n] = idx;
                n = n + 1u;
            }
        }
        st[subset] = n;
        var r = ccresults_new();
        let refine = (num_solutions <= 2u) || refine_force;
        let err = color_cell_compression(
            mode, p, &r,
            params.pbit_search != 0u, params.refinement_passes,
            params.uber_level, params.uber1_mask,
            n, &sub_px, refine,
        );
        for (var i = 0u; i < n; i = i + 1u) {
            ssel[subset * 16u + i] = r.selectors[i];
        }
        slow[subset] = r.low;
        shigh[subset] = r.high;
        spb[subset] = r.pbits;
        trial_err = add64(trial_err, err);
        if (lt64(*best_err, trial_err)) {
            ok = false;
            break;
        }
    }
    if (ok && lt64(trial_err, *best_err)) {
        *best_err = trial_err;
        (*opt).mode = mode;
        (*opt).index_selector = 0u;
        (*opt).rotation = 0u;
        (*opt).partn = trial_partition;
        for (var subset = 0u; subset < total_subsets; subset = subset + 1u) {
            for (var i = 0u; i < st[subset]; i = i + 1u) {
                (*opt).selectors[spi[subset * 16u + i]] = ssel[subset * 16u + i];
            }
            (*opt).low[subset] = slow[subset];
            (*opt).high[subset] = shigh[subset];
            if (mode == 1u) {
                (*opt).pbits[subset].x = spb[subset].x;
            } else if (mode != 2u) {
                (*opt).pbits[subset] = spb[subset];
            }
        }
    }
}

fn run_mode_list(
    mode: u32,
    subsets3: bool,
    rerun: bool,
    force_refine: bool,
    p: CCParams,
    sols: ptr<function, SolutionList>,
    best_err: ptr<function, vec2<u32>>,
    opt: ptr<function, OptResults>,
    px: ptr<function, array<vec4<i32>, 16>>,
) {
    let ns = (*sols).len;
    var iters = ns;
    if (rerun && ns > 2u) {
        iters = ns + 1u;
    }
    for (var si = 0u; si < iters; si = si + 1u) {
        var tp = 0u;
        var force = force_refine;
        if (si == ns) {
            if ((*opt).mode != mode) {
                break;
            }
            tp = (*opt).partn;
            force = true;
        } else {
            tp = (*sols).sols[si].index;
        }
        run_subsets(mode, subsets3, p, ns, tp, force, best_err, opt, px);
    }
}

fn compress_trials(
    px: ptr<function, array<vec4<i32>, 16>>,
    is_alpha: bool,
    hint: u32,
    lo_a: i32,
    hi_a: i32,
    plan: ptr<function, PartitionPlan>,
) -> vec4<u32> {
    var base = base_ccparams();
    if (is_alpha) {
        base.perceptual = params.perceptual != 0u;
    }
    var opt: OptResults;
    var best_err = U64_MAX;
    var sols2: SolutionList;
    if (!is_alpha && (params.use_mode[1] != 0u || params.use_mode[3] != 0u)) {
        if ((*plan).use_list13 != 0u) {
            sols2 = (*plan).list13;
        } else {
            sols2.sols[0].index = (*plan).part13;
            sols2.sols[0].err = vec2<u32>(0u, 0u);
            sols2.len = 1u;
        }
    }
    var nsteps = 7u;
    if (is_alpha) {
        nsteps = 4u;
    }
    for (var step = 0u; step < nsteps; step = step + 1u) {
        var kind: u32;
        var mode: u32;
        if (is_alpha) {
            if (step == 0u) { kind = TK_MODE4; mode = 4u; }
            else if (step == 1u) { kind = TK_MODE6; mode = 6u; }
            else if (step == 2u) { kind = TK_MODE5; mode = 5u; }
            else { kind = TK_LIST; mode = 7u; }
        } else {
            if (step == 0u) { kind = TK_MODE6; mode = 6u; }
            else if (step == 1u) { kind = TK_LIST; mode = 1u; }
            else if (step == 2u) { kind = TK_LIST; mode = 0u; }
            else if (step == 3u) { kind = TK_LIST; mode = 3u; }
            else if (step == 4u) { kind = TK_MODE5; mode = 5u; }
            else if (step == 5u) { kind = TK_LIST; mode = 2u; }
            else { kind = TK_MODE4; mode = 4u; }
        }
        if (kind == TK_MODE4 || kind == TK_MODE5) {
            var enabled: bool;
            var num_rotations = 4u;
            if (is_alpha) {
                if (kind == TK_MODE4) {
                    enabled = hinted_params_word(36u, hint) != 0u;
                    if (base.perceptual || params.use_mode4_rotation == 0u) {
                        num_rotations = 1u;
                    }
                } else {
                    enabled = hinted_params_word(37u, hint) != 0u;
                    if (base.perceptual || params.use_mode5_rotation == 0u) {
                        num_rotations = 1u;
                    }
                }
            } else {
                enabled = params.perceptual == 0u && params.use_mode[mode] != 0u;
            }
            if (!enabled) {
                continue;
            }
            var rot_mask = params.mode4_rotation_mask;
            if (kind == TK_MODE5) {
                rot_mask = params.mode5_rotation_mask;
            }
            for (var rotation = 0u; rotation < num_rotations; rotation = rotation + 1u) {
                if ((rot_mask & (1u << rotation)) == 0u) {
                    continue;
                }
                var pr = base;
                pr.weights = rotate_weights(pr.weights, rotation);
                var rp: array<vec4<i32>, 16>;
                var tlo = 255;
                var thi = 255;
                if (is_alpha) {
                    tlo = lo_a;
                    thi = hi_a;
                }
                rotate_block(px, rotation, &rp, &tlo, &thi);
                var trial: OptResults;
                if (kind == TK_MODE4) {
                    var trial_err = best_err;
                    handle_alpha_block_mode4(&rp, pr, tlo, thi, &trial, &trial_err);
                    if (lt64(trial_err, best_err)) {
                        best_err = trial_err;
                        opt.mode = 4u;
                        opt.index_selector = trial.index_selector;
                        opt.rotation = rotation;
                        opt.partn = 0u;
                        opt.low[0] = trial.low[0];
                        opt.high[0] = trial.high[0];
                        for (var i = 0u; i < 16u; i = i + 1u) {
                            opt.selectors[i] = trial.selectors[i];
                            opt.alpha_selectors[i] = trial.alpha_selectors[i];
                        }
                    }
                } else {
                    let e5 = handle_alpha_block_mode5(&rp, pr, tlo, thi, &trial);
                    if (lt64(e5, best_err)) {
                        best_err = e5;
                        opt = trial;
                        opt.rotation = rotation;
                    }
                }
            }
        } else if (kind == TK_MODE6) {
            var enabled = params.use_mode[6] != 0u;
            if (is_alpha) {
                enabled = hinted_params_word(38u, hint) != 0u;
            }
            if (!enabled) {
                continue;
            }
            var p6 = base;
            if (is_alpha) {
                p6.weights = mode67_mul(p6.weights);
                p6.has_alpha = true;
            }
            p6.sel_table = 2u;
            p6.num_selector_weights = 16u;
            p6.comp_bits = 7u;
            p6.has_pbits = true;
            p6.endpoints_share_pbit = false;
            p6.perceptual = params.perceptual != 0u;
            var r6 = ccresults_new();
            let e6 = color_cell_compression(
                6u, p6, &r6,
                params.pbit_search != 0u, params.refinement_passes,
                params.uber_level, params.uber1_mask,
                16u, px, true,
            );
            if (lt64(e6, best_err)) {
                best_err = e6;
                opt.mode = 6u;
                opt.index_selector = 0u;
                opt.rotation = 0u;
                opt.partn = 0u;
                opt.low[0] = r6.low;
                opt.high[0] = r6.high;
                opt.pbits[0] = r6.pbits;
                for (var i = 0u; i < 16u; i = i + 1u) {
                    opt.selectors[i] = r6.selectors[i];
                }
            }
        } else {
            var enabled: bool;
            if (mode == 7u) {
                enabled = hinted_params_word(39u, hint) != 0u;
            } else {
                enabled = params.use_mode[mode] != 0u;
            }
            if (!enabled) {
                continue;
            }
            var p = base;
            var sols: SolutionList;
            var subsets3 = false;
            var rerun = false;
            var force_refine = false;
            if (mode == 7u) {
                p.weights = mode67_mul(p.weights);
                p.sel_table = 0u;
                p.num_selector_weights = 4u;
                p.comp_bits = 5u;
                p.has_pbits = true;
                p.endpoints_share_pbit = false;
                p.has_alpha = true;
                sols = (*plan).list7;
                rerun = true;
            } else if (mode == 1u) {
                p.sel_table = 1u;
                p.num_selector_weights = 8u;
                p.comp_bits = 6u;
                p.has_pbits = true;
                p.endpoints_share_pbit = true;
                p.perceptual = params.perceptual != 0u;
                sols = sols2;
                rerun = true;
            } else if (mode == 3u) {
                p.sel_table = 0u;
                p.num_selector_weights = 4u;
                p.comp_bits = 7u;
                p.has_pbits = true;
                p.endpoints_share_pbit = false;
                p.perceptual = params.perceptual != 0u;
                sols = sols2;
                rerun = true;
            } else if (mode == 0u) {
                p.sel_table = 1u;
                p.num_selector_weights = 8u;
                p.comp_bits = 4u;
                p.has_pbits = true;
                p.endpoints_share_pbit = false;
                p.perceptual = params.perceptual != 0u;
                subsets3 = true;
                force_refine = true;
                if ((*plan).use_list0 != 0u) {
                    sols = (*plan).list0;
                } else {
                    sols.sols[0].index = (*plan).part0;
                    sols.sols[0].err = vec2<u32>(0u, 0u);
                    sols.len = 1u;
                }
            } else {
                p.sel_table = 0u;
                p.num_selector_weights = 4u;
                p.comp_bits = 5u;
                p.has_pbits = false;
                p.endpoints_share_pbit = false;
                p.perceptual = params.perceptual != 0u;
                subsets3 = true;
                force_refine = true;
                if ((*plan).use_list2 != 0u) {
                    sols = (*plan).list2;
                } else {
                    sols.sols[0].index = (*plan).part2;
                    sols.sols[0].err = vec2<u32>(0u, 0u);
                    sols.len = 1u;
                }
            }
            run_mode_list(mode, subsets3, rerun, force_refine, p, &sols, &best_err, &opt, px);
        }
    }
    return encode_bc7_block_bits(&opt);
}

fn handle_opaque_block_mode6(px: ptr<function, array<vec4<i32>, 16>>) -> vec4<u32> {
    var p = base_ccparams();
    p.sel_table = 2u;
    p.num_selector_weights = 16u;
    p.comp_bits = 7u;
    p.has_pbits = true;
    p.endpoints_share_pbit = false;
    p.perceptual = params.perceptual != 0u;
    var r6 = ccresults_new();
    _ = color_cell_compression(
        6u, p, &r6,
        params.pbit_search != 0u, params.refinement_passes,
        params.uber_level, params.uber1_mask,
        16u, px, true,
    );
    var opt: OptResults;
    opt.mode = 6u;
    opt.index_selector = 0u;
    opt.rotation = 0u;
    opt.partn = 0u;
    opt.low[0] = r6.low;
    opt.high[0] = r6.high;
    opt.pbits[0] = r6.pbits;
    for (var i = 0u; i < 16u; i = i + 1u) {
        opt.selectors[i] = r6.selectors[i];
    }
    return encode_bc7_block_mode6(&opt);
}

const PLAN_STRIDE: u32 = 110u;

fn write_plan_sol_list(base: u32, lst: SolutionList) {
    for (var i = 0u; i < SOL_CAP; i = i + 1u) {
        out_words[base + i * 3u] = lst.sols[i].index;
        out_words[base + i * 3u + 1u] = lst.sols[i].err.x;
        out_words[base + i * 3u + 2u] = lst.sols[i].err.y;
    }
    out_words[base + 24u] = lst.len;
}

fn read_plan_sol_list(base: u32) -> SolutionList {
    var lst: SolutionList;
    for (var i = 0u; i < SOL_CAP; i = i + 1u) {
        lst.sols[i].index = plans[base + i * 3u];
        lst.sols[i].err = vec2<u32>(plans[base + i * 3u + 1u], plans[base + i * 3u + 2u]);
    }
    lst.len = plans[base + 24u];
    return lst;
}

@compute @workgroup_size(64)
fn bc7_plan_alpha(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let start = gid * GROUP_WIDTH;
    var n = job.n_items - start;
    if (n > GROUP_WIDTH) {
        n = GROUP_WIDTH;
    }
    var apx: array<vec4<i32>, 64>;
    var alpha_idx: array<u32, 4>;
    var alpha_n = 0u;
    for (var k = 0u; k < n; k = k + 1u) {
        var px: array<vec4<i32>, 16>;
        block_from_words((start + k) * 16u, &px);
        let c = classify_block(&px);
        let base = (start + k) * PLAN_STRIDE;
        out_words[base] = c;
        if (c == CLASS_ALPHA) {
            var lo_a = 255;
            var hi_a = 0;
            for (var i = 0u; i < 16u; i = i + 1u) {
                lo_a = min(lo_a, px[i].w);
                hi_a = max(hi_a, px[i].w);
            }
            out_words[base + 1u] = bitcast<u32>(lo_a);
            out_words[base + 2u] = bitcast<u32>(hi_a);
            out_words[base + 3u] = apply_mode_tree_hint(&px);
            for (var i = 0u; i < 16u; i = i + 1u) {
                apx[alpha_n * 16u + i] = px[i];
            }
            alpha_idx[alpha_n] = k;
            alpha_n = alpha_n + 1u;
        }
    }
    if (alpha_n != 0u && params.use_mode7 != 0u) {
        var lists: array<SolutionList, 4>;
        est_list_group2(7u, i32(params.al_max_mode7), alpha_n, &apx, &lists);
        for (var k = 0u; k < alpha_n; k = k + 1u) {
            write_plan_sol_list((start + alpha_idx[k]) * PLAN_STRIDE + 85u, lists[k]);
        }
    }
}

fn gather_opaque(
    start: u32,
    n: u32,
    opx: ptr<function, array<vec4<i32>, 64>>,
    opaque_idx: ptr<function, array<u32, 4>>,
) -> u32 {
    var opaque_n = 0u;
    for (var k = 0u; k < n; k = k + 1u) {
        var px: array<vec4<i32>, 16>;
        block_from_words((start + k) * 16u, &px);
        let c = classify_block(&px);
        if (c == CLASS_OPAQUE && params.mode6_only == 0u) {
            for (var i = 0u; i < 16u; i = i + 1u) {
                (*opx)[opaque_n * 16u + i] = px[i];
            }
            (*opaque_idx)[opaque_n] = k;
            opaque_n = opaque_n + 1u;
        }
    }
    return opaque_n;
}

@compute @workgroup_size(64)
fn bc7_plan_opaque13(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let start = gid * GROUP_WIDTH;
    var n = job.n_items - start;
    if (n > GROUP_WIDTH) {
        n = GROUP_WIDTH;
    }
    var opx: array<vec4<i32>, 64>;
    var opaque_idx: array<u32, 4>;
    let opaque_n = gather_opaque(start, n, &opx, &opaque_idx);
    if (opaque_n == 0u || (params.use_mode[1] == 0u && params.use_mode[3] == 0u)) {
        return;
    }
    if (params.op_max_mode13 == 1u) {
        for (var k = 0u; k < opaque_n; k = k + 1u) {
            var px: array<vec4<i32>, 16>;
            for (var i = 0u; i < 16u; i = i + 1u) {
                px[i] = opx[k * 16u + i];
            }
            let base = (start + opaque_idx[k]) * PLAN_STRIDE;
            out_words[base + 5u] = estimate_partition(1u, &px);
        }
    } else {
        var lists: array<SolutionList, 4>;
        est_list_group2(1u, i32(params.op_max_mode13), opaque_n, &opx, &lists);
        for (var k = 0u; k < opaque_n; k = k + 1u) {
            let base = (start + opaque_idx[k]) * PLAN_STRIDE;
            out_words[base + 7u] = 1u;
            write_plan_sol_list(base + 10u, lists[k]);
        }
    }
}

@compute @workgroup_size(64)
fn bc7_plan_opaque02(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    let start = gid * GROUP_WIDTH;
    var n = job.n_items - start;
    if (n > GROUP_WIDTH) {
        n = GROUP_WIDTH;
    }
    var opx: array<vec4<i32>, 64>;
    var opaque_idx: array<u32, 4>;
    let opaque_n = gather_opaque(start, n, &opx, &opaque_idx);
    for (var k = 0u; k < opaque_n; k = k + 1u) {
        var px: array<vec4<i32>, 16>;
        for (var i = 0u; i < 16u; i = i + 1u) {
            px[i] = opx[k * 16u + i];
        }
        let base = (start + opaque_idx[k]) * PLAN_STRIDE;
        if (params.use_mode[0] != 0u) {
            if (params.op_max_mode0 == 1u) {
                out_words[base + 4u] = estimate_partition(0u, &px);
            } else {
                out_words[base + 9u] = 1u;
                write_plan_sol_list(
                    base + 60u,
                    estimate_partition_list(0u, i32(params.op_max_mode0), &px),
                );
            }
        }
        if (params.use_mode[2] != 0u) {
            if (params.op_max_mode2 == 1u) {
                out_words[base + 6u] = estimate_partition(2u, &px);
            } else {
                out_words[base + 8u] = 1u;
                write_plan_sol_list(
                    base + 35u,
                    estimate_partition_list(2u, i32(params.op_max_mode2), &px),
                );
            }
        }
    }
}

override TRIAL_CLASS: u32 = 3u;

@compute @workgroup_size(64)
fn bc7_encode_blocks(@builtin(global_invocation_id) giv: vec3<u32>) {
    let gid = job.gid_base + giv.x;
    if (gid >= job.total) {
        return;
    }
    var px: array<vec4<i32>, 16>;
    block_from_words(gid * 16u, &px);
    let pbase = gid * PLAN_STRIDE;
    let cls = plans[pbase];
    let want_solid = TRIAL_CLASS == 0u || TRIAL_CLASS == 3u;
    let want_alpha = TRIAL_CLASS == 1u || TRIAL_CLASS == 3u;
    let want_opaque = TRIAL_CLASS == 2u || TRIAL_CLASS == 3u;
    if (want_solid && cls == CLASS_SOLID) {
        let c = px[0];
        write_block(gid * 4u, handle_block_solid(u32(c.x), u32(c.y), u32(c.z), c.w));
        return;
    }
    if (want_solid && cls == CLASS_OPAQUE && params.mode6_only != 0u) {
        write_block(gid * 4u, handle_opaque_block_mode6(&px));
        return;
    }
    if (want_alpha && cls == CLASS_ALPHA) {
        let lo_a = bitcast<i32>(plans[pbase + 1u]);
        let hi_a = bitcast<i32>(plans[pbase + 2u]);
        let hint = plans[pbase + 3u];
        var plan: PartitionPlan;
        plan.list7 = read_plan_sol_list(pbase + 85u);
        write_block(gid * 4u, compress_trials(&px, true, hint, lo_a, hi_a, &plan));
        return;
    }
    if (want_opaque && cls == CLASS_OPAQUE && params.mode6_only == 0u) {
        var plan: PartitionPlan;
        plan.part0 = plans[pbase + 4u];
        plan.part13 = plans[pbase + 5u];
        plan.part2 = plans[pbase + 6u];
        plan.use_list13 = plans[pbase + 7u];
        plan.use_list2 = plans[pbase + 8u];
        plan.use_list0 = plans[pbase + 9u];
        plan.list13 = read_plan_sol_list(pbase + 10u);
        plan.list2 = read_plan_sol_list(pbase + 35u);
        plan.list0 = read_plan_sol_list(pbase + 60u);
        write_block(gid * 4u, compress_trials(&px, false, 0u, 0, 0, &plan));
    }
}


