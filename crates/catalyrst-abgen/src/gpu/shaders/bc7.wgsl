// Layout contract (std430): BC7 encode tables + params, mirroring kernel-ptx/src/core/bc7.rs
// and mode_tree.rs. ParamsGpu is a NEW one-u32-per-bool layout (42 words / 168 B) produced by
// wgpu_bc7::params_words -- NOT a memcpy of repr(C) Params (size 124, packed bools).
// EndpointErr {error:u16, lo:u8, hi:u8} travels as one LE u32 word: error | lo<<16 | hi<<24.
// OptTables (repr(C), 17408 B, u32-word-clean) binds as array<u32> of 4352 words; word offsets:
// mode0@0 mode1@1024 mode6@1536 mode7@2560 mode5@3584 mode4_3@3840 mode4_2@4096.
// Const tables below are script-extracted from the Rust source (exact f32 bits); see
// docs/testing/abgpugen-multibackend-20260708/bc7-wgsl-01-mirrors/ for the extraction script.

// Meta.fone MUST carry the f32 bits of 1.0 (0x3f800000): the math core routes every
// non-exact float op through fone/fzero barriers (pmul/padd/psub/pval below) to defeat
// FMA contraction AND add/mul-chain reassociation — see the barrier contract comment
// next to padd/psub/pval.
struct Meta {
    n_items: u32,
    total: u32,
    gid_base: u32,
    fone: u32,
}

struct ParamsGpu {
    max_partitions_mode: array<u32, 8>,
    weights: array<u32, 4>,
    uber_level: u32,
    refinement_passes: u32,
    mode4_rotation_mask: u32,
    mode4_index_mask: u32,
    mode5_rotation_mask: u32,
    uber1_mask: u32,
    perceptual: u32,
    pbit_search: u32,
    mode6_only: u32,
    op_max_mode13: u32,
    op_max_mode0: u32,
    op_max_mode2: u32,
    use_mode: array<u32, 7>,
    al_max_mode7: u32,
    mode67_weight_mul: array<u32, 4>,
    use_mode4: u32,
    use_mode5: u32,
    use_mode6: u32,
    use_mode7: u32,
    use_mode4_rotation: u32,
    use_mode5_rotation: u32,
}

@group(0) @binding(0) var<uniform> job: Meta;
@group(0) @binding(1) var<storage, read> params: ParamsGpu;
@group(0) @binding(2) var<storage, read> opt_tables: array<u32>;
@group(0) @binding(3) var<storage, read_write> out_words: array<u32>;

