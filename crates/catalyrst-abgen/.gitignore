# Generated C/C++ build artifacts (cmake out-of-source builds in the vendored
# third_party crates). Must never be committed/vendored: the cmake cache bakes
# an absolute path, so a stale copy breaks the build in a new location (incl. the
# nix sandbox). cmake regenerates these from source.
/target
third_party/draco_decoder/third_party/draco/build/
third_party/**/build/
**/CMakeCache.txt
**/CMakeFiles/
*.a
*.o
# Runtime caches / env
/abgen-serve-cache
*.env
.env
.env.*
__pycache__/
.DS_Store
*.swp

# abgen-compare persistent tool config (machine-local unity_editor/
# unity_project paths — pipeline/abgencompare/toolconfig.py documents it as
# never-commit)
/abgen-compare.json

# wasm lab build artifacts — wasm-poc/build.sh regenerates the module
/wasm-poc/target/
/site/wasm/abgen_poc.wasm

# abgen-compare scratch run outputs — the default runs root is <repo>/runs
# when $ABGEN_RUNS_DIR is unset (render/compare artifacts, not source)
/runs/
