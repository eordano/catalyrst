# Template env file for the catalyrst-camera-reel service.
# Provision a read/write role on the places_events DB (uploads INSERT,
# deletes/visibility mutate camera_reel_images) and fill in user/password below.

HTTP_SERVER_HOST=127.0.0.1
HTTP_SERVER_PORT=5143

# Postgres connection to the places_events DB.
CAMERA_REEL_PG_CONNECTION_STRING="postgresql://<DB_USER>:<DB_PASSWORD>@<HOST>:5433/places_events"

# Content-addressed disk store root (ContentStorage appends a contents/ subdir).
CONTENT_STORAGE_DIR=<DATA_DIR>/camera-reel

# Public base used to build image.url / thumbnailUrl => {API_URL}/api/images/{hash}
API_URL=http://127.0.0.1:5143

MAX_IMAGES_PER_USER=500

# World .eth -> place-id resolution against the catalyrst-places service.
PLACES_API_URL=http://127.0.0.1:5134
PLACES_CACHE_TTL_SECONDS=300
PLACES_CACHE_MAX_SIZE=1000

RUST_LOG=catalyrst_camera_reel=info,tower_http=info
