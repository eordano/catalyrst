# catalyrst-price — thin serving layer over the mana_price archive
# Install to <WORKSPACE>/env/catalyrst-price.env

HTTP_SERVER_HOST=127.0.0.1
HTTP_SERVER_PORT=5144

# Postgres user. Needs write access to price_snapshots when PRICE_POLL_ENABLED=true,
# otherwise read-only is sufficient.
PRICE_PG_COMPONENT_PSQL_CONNECTION_STRING="postgresql:///mana_price?host=<DB_HOST>&port=5433&user=<DB_USER>&password=<DB_PASSWORD>"

# --- Background CoinGecko poller (optional) ---------------------------------
# When true, this crate runs its own MANA spot-price poller (writes
# price_snapshots, source='coingecko'). When false (default) it only serves
# whatever an external archive ingester wrote.
PRICE_POLL_ENABLED=false
# CoinGecko API base, no trailing slash.
COINGECKO_URL=https://api.coingecko.com/api/v3
# Seconds between poll snapshots (default 300 = 5 minutes).
PRICE_POLL_INTERVAL_SECS=300

RUST_LOG=catalyrst_price=info,tower_http=info
