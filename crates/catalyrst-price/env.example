# catalyrst-price — thin serving layer over the mana_price archive
# Install to <WORKSPACE>/env/catalyrst-price.env

HTTP_SERVER_HOST=127.0.0.1
HTTP_SERVER_PORT=5144

# Read-only Postgres user.
PRICE_PG_COMPONENT_PSQL_CONNECTION_STRING="postgresql:///mana_price?host=<DB_HOST>&port=5433&user=<DB_USER>&password=<DB_PASSWORD>"

RUST_LOG=catalyrst_price=info,tower_http=info
