# Example configuration. Copy to catalyrst-lists.env and fill in real values
# (provision a database role with SELECT on lists_poi / lists_banned_name).

HTTP_SERVER_HOST=127.0.0.1
HTTP_SERVER_PORT=5143

# Connection string for the places_events database. The role needs SELECT on
# lists_poi / lists_banned_name (and the places tables it reads from).
PLACES_PG_COMPONENT_PSQL_CONNECTION_STRING=postgres://<DB_USER>:<DB_PASSWORD>@<HOST>:5433/places_events

RUST_LOG=catalyrst_lists=info,tower_http=info
